  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "objet élaboré par l'humain créé pour l'observation des phénomènes naturels ou pour l'application des connaissances tirées de ces observations"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Objet pour les sciences ou la technologie"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
