    "@value" : "surface photosensible"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "surface qui réagit à l'exposition d'un rayonnement électromagnétique et qui permet d'enregistrer et de reconstituer une image"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "surface photosensible"
  } ],
  "https://stgermain.ebsi.umontreal.ca/miron/synonyme" : [ {
    "@language" : "fr",
    "@value" : "surface sensible"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/ee1866cf_de4f_4355_b37b_54f1db265c20",
