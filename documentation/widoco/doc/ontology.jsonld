    "@value" : "https://usito.usherbrooke.ca/d%C3%A9finitions/orignal"
  }, {
    "@value" : "https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8871650/orignal"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
