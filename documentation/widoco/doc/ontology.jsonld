    "@language" : "fr",
    "@value" : "procédé ou technique d’impression"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/Insecte",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://usito.usherbrooke.ca/d%C3%A9finitions/insecte"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "petit animal invertébré de type arthropode, pourvu de deux antennes, de trois paires de pattes et, chez la plupart des espèces, d’une ou de deux paires d’ailes, dont le corps présente trois parties principales bien distinctes (la tête, le thorax et l’abdomen) et dont le développement complet comporte généralement différents stades (larve, nymphe, adulte) et d’importantes métamorphoses"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Insecte"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/Animal"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "insecte"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/MIR0001",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://nomenclature.info/nom/10708"
  }, {
    "@value" : "https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/17058634/accordéon"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "instrument à vent composé de deux boîtiers rectangulaires en bois ou en métal reliés par un soufflet extensible en cuir, chacun munis à l'intérieur de plusieurs anches en métal reliées à l'extérieur à un clavier à touches et à boutons, généralement avec des bretelles en cuir, et servant à produire des sons et des accords par l'action de l'air du soufflet et la pression des touches ou des boutons sur les anches libres"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Accordéon"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT006_422"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid78"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "accordéon"
  } ]
}, {
