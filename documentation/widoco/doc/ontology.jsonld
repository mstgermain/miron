}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/Impression",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "http://vocab.getty.edu/page/aat/300053319"
  }, {
