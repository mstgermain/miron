  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "objet de correspondance sans enveloppe, consistant en une feuille de papier fort et rigide, dont l'une des faces est entièrement réservée à la correspondance, la moitié droite au moins de l'autre face (recto selon la terminologie postale) étant réservée à l'adresse du destinataire, à l'affranchissement et aux indications postales"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Carte postale"
  } ],
