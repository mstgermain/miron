    "@language" : "fr",
    "@value" : "objet pour la communication créé pour faciliter la communication entre les personnes par l'intermédiaire de documents écrits, soit la préparation et la gestion de ces documents"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
