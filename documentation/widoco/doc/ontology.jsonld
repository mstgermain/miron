    "@value" : "objet pour la communication créé pour générer, amplifier, reproduire ou stocker de la musique, des mots parlés ou d'autres sons utiles à la communication humaine, à l’exception des instruments de musique"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
