  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://nomenclature.info/nom/3176"
  }, {
    "@value" : "https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#Categorie4"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "objet élaboré par l'humain créé pour contrôler, surveiller, récolter ou recueillir des ressources ou pour transformer, modifier ou servir certaines matières, premières ou transformées"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Objet pour le traitement des matériaux"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid2"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fr",
    "@value" : "outillage et équipement pour le traitement de matières premières"
  }, {
    "@language" : "fr",
    "@value" : "outillage et équipement pour le traitement des matériaux"
  } ],
  "http://www.w3.org/2004/02/skos/core#hiddenLabel" : [ {
    "@language" : "fr",
    "@value" : "catégorie 04"
  }, {
    "@language" : "fr",
    "@value" : "catégorie 4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "objet pour le traitement des matériaux"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fr",
    "@value" : "Les objets pour le traitement des matériaux sont normalement créés pour résoudre des problèmes inhérents aux matériaux eux-mêmes. Ainsi, le bois, par exemple, exige certains types d'appareils de coupe; la pêche nécessite certains appâts; la nourriture requiert certains ustensiles de service et de transformation."
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT004_1",
