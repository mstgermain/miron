  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT001"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fr",
    "@value" : "Bâtiment"
  }, {
    "@language" : "fr",
    "@value" : "Constructions"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "section d'un mur;section d'un toit"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "construction"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fr",
    "@value" : "Les constructions peuvent être permantentes, portatives, à régulation climatique ou à libre circulation de l'air et peuvent servir à diverses fins cérémonielles, agricoles, récréatives, commerciales, culturelles, civiques, industrielles ou sociales."
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT002",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
