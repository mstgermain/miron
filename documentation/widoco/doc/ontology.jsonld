  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fr",
    "@value" : "outils et équipement, peinture"
  }, {
    "@language" : "fr",
    "@value" : "peinture et recouvrement"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "couteau à mastiquer;palette;pinceau"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "objet pour la peinture ou le recouvrement"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fr",
    "@value" : "Cette classe comprend les outils, l’équipement et les fournitures utilisés à des fins décoratives, artistiques et de protection."
  } ]
