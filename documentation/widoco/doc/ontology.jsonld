    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/MIR0100"
  } ],
  "http://www.w3.org/2004/02/skos/core#hiddenLabel" : [ {
    "@language" : "fr",
    "@value" : "assiette à desserts"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "assiette à dessert"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/MIR0009",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "http://vocab.getty.edu/page/aat/300423508"
  }, {
    "@value" : "https://nomenclature.info/nom/4867"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "souvenir ayant la forme d'une assiette orné de l'image d'un événement, d'un lieu ou d'une personne que l'on souhaite commémorer, destiné à être collectionnée ou accrochée comme décoration, plutôt que pour contenir des aliments lors d'un repas"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Assiette commémorative"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT008_21"
  }, {
    "@id" : "_:genid128"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "assiette commémorative"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fr",
    "@value" : "Bien que l'assiette commémorative ait la forme d'une assiette destinée au service des aliments, on ne peut la classifier comme telle étant donné que la classification des objets ici préconisée repose d'abord sur leur utilisation prévue."
  } ]
}, {
