    "@value" : "https://nomenclature.info/nom/1499"
  }, {
    "@value" : "https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat2_1"
  } ],
