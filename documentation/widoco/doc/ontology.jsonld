    "@language" : "fr",
    "@value" : "objet élaboré par l'humain créé pour faciliter l'activité humaine et pour répondre aux besoins matériels des personnes, en assurant confort, commodité ou protection"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Objet pour l’ameublement de l’environnement bâti"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
