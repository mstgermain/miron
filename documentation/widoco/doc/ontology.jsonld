}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/Mammifere",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8980247/mammiferes"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "animal appartenant à l'embranchement des vertébrés, dont les individus se caractérisent par la présence de glandes mammaires, d'osselets de l'ouïe, d'une mâchoire inférieure s'articulant directement avec le crâne et de poils sur la peau à un moment ou un autre de leur développement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Mammifère"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/Animal"
  } ],
