    "@language" : "fr",
    "@value" : "mammifère"
  } ],
  "https://stgermain.ebsi.umontreal.ca/miron/synonyme" : [ {
    "@language" : "fr",
    "@value" : "mammalia"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/Oiseau",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://usito.usherbrooke.ca/d%C3%A9finitions/oiseau"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "animal vertébré, le plus souvent de petite taille, à peau recouverte de plumes, qui est pourvu d’un bec corné, de deux pattes écailleuses griffues et de deux ailes généralement bien adaptées au vol, dont la femelle pond des œufs et qui, selon les espèces, peut émettre des chants plus ou moins développés et présenter des coloris de plumage variables selon l’âge, le sexe ou la saison"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Oiseau"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/Animal"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "oiseau"
  } ]
