  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "procédé ou technique de reproduction par pression ou contact d'une surface, généralement une plaque, un bloc, une pierre ou un écran, portant des traces enduites d'encre correspondant à une image picturale ou textuelle sur une autre, généralement en papier ou en tissu, qui en reçoit l'empreinte"
  } ],
