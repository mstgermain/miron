    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/02712e9b_d956_4a33_9cdb_ac6cf91e3cab"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/f37c006e_72a6_4015_86da_412275abbd98",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://www.cnrtl.fr/definition/eucharistie"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/MIR0260"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "eucharistie"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "sacrement contenant le corps, le sang et la divinité du Christ au terme de la transsubstantiation du pain et du vin, renouvelant rituellement en action de grâce le sacrifice du Christ et constituant la nourriture des fidèles et le symbole de leur unité"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "eucharistie"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/f4e40103_2809_47fa_974c_3aaa1ceffba2",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://usito.usherbrooke.ca/d%C3%A9finitions/carbone"
  }, {
