    "@language" : "fr",
    "@value" : "large récipient circulaire, généralement muni de deux poignées, uniquement en métal, servant à la cuisson de différents aliments, et dont la forme peut varier selon l'emploi auquel la bassine est destinée"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Bassine"
  } ],
