    "@value" : "https://usito.usherbrooke.ca/d%C3%A9finitions/rebord"
  }, {
    "@value" : "https://www.cnrtl.fr/definition/rebord"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
