    "@language" : "fr",
    "@value" : "objet pour l'ameublement de l'environnement bâti créé pour être disposé à l'intérieur ou autour d'un bâtiment pour la commodité des personnes, c'est-à-dire afin d'améliorer, de compléter ou de faciliter l'entretien de leur environnement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Accessoire ménager"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT002"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fr",
    "@value" : "accessoire de maison"
  }, {
    "@language" : "fr",
    "@value" : "accessoires ménagers"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "porte-savon;crachoir;aquarium;cendrier;têtière;nappe;plateau de cartes de visite;caisse"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "accessoire ménager"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fr",
    "@value" : "Cette classe comprend de petits accessoires, des objets autres que du mobilier servant au rangement et à la présentation ainsi que des objets protégeant les meubles."
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT002_2",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
