    "@language" : "fr",
    "@value" : "assiette, plus petite qu'une assiette plate utilisée au moment du plat principal, servant à mettre ou recevoir de la nourriture à table, lors du moment du repas où est servi le dessert"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Assiette à dessert"
  } ],
