    "@language" : "fr",
    "@value" : "ameublement et accessoires"
  }, {
    "@language" : "fr",
    "@value" : "ameublement et décoration"
  } ],
  "http://www.w3.org/2004/02/skos/core#hiddenLabel" : [ {
    "@language" : "fr",
    "@value" : "catégorie 02"
  }, {
    "@language" : "fr",
    "@value" : "catégorie 2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "objet pour l’ameublement de l’environnement bâti"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fr",
    "@value" : "L'ameublement est constitué d'objets permettant l'activité humaine en lui fournissant un cadre passif."
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT002_1",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
