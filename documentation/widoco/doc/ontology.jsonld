    "@value" : "https://nomenclature.info/nom/12895"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "moyen d'expression créé comme œuvre décorative perçue par le sens de la vue"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
