    "@language" : "fr",
    "@value" : "arme blanche composée d'une tige de bois, de métal ou de fibre de verre fortement recourbée par une corde fixée à ses deux extrémités, servant à lancer des flèches"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
