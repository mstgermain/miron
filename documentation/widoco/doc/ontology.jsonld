    "@value" : "réconciliation ou pénitence"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "sacrement catholique par lequel le prêtre donne l’absolution au confessé et par lequel un pécheur se réconcilie avec Dieu, avec l'Église"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "réconciliation ou pénitence"
  } ]
