}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/effb3826_a168_41e8_8f15_c848f068a076",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "http://vocab.getty.edu/page/aat/300014502"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/MIR0256"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "vinyle"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "plastique dérivé du chlorure de vinyle, de l'acétate de vinyle ou du chlorure de vinylidène"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "vinyle"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fr",
    "@value" : "Le terme est couramment utilisé pour désigner tous les polymères et copolymères dont le chlorure de vinyle est un constituant."
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/elementObjet",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Chose matérielle élaborée par l'humain » à une ou plusieurs instances de la classe « Objet élaboré par l’humain » possédant une structure définie reflétant son découpage en composantes (éléments) entretenant une relation fonctionnelle avec le tout"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "fait partie de"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/objetElement"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette propriété correspond à la relation partitive Élément-Objet."
  }, {
    "@language" : "fr",
    "@value" : "Cette relation possède la propriété de fonctionnalité, c'est-à-dire que le concept partitif (élément) remplit une fonction du concept intégrant (objet)."
  }, {
    "@language" : "fr",
    "@value" : "Cette relation possède la propriété de séparabilité, c'est-à-dire que le concept partitif (élément) peut être séparé du concept intégrant (objet) sans que l'identité du concept intégrant ne soit affectée."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "une anse (Caractéristique élaborée par l'humain) fait partie de (elementObjet) une tasse (Objet pour le service des aliments)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/ensembleMembre",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#TransitiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Objet élaboré par l'humain » à une ou plusieurs instances de la même classe qui fait partie d'un ensemble impliquant une proximité avec les membres et non pas une similarité, chaque membre occupant une fonction spécifique dans l'ensemble"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "est composé de"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/membreEnsemble"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette propriété correspond à la relation partitive Ensemble-Membre."
  }, {
    "@language" : "fr",
    "@value" : "Cette relation possède la propriété de séparabilité, c'est-à-dire que le concept partitif (membre) peut être séparé du concept intégrant (ensemble) sans que l'identité du concept intégrant ne soit affectée."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "un jeu de dames (Objet pour le jeu) est composé de (ensembleMembre) un pion (Accessoire ou composant de jeu)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/f0493811_5856_4437_ae58_64ffe4f36d7b",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://usito.usherbrooke.ca/d%C3%A9finitions/faisceau"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/COMP001_3"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "faisceau"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "assemblage de choses de même nature et de forme allongée, liées ensemble ou qui convergent à une de leur extrémité"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "faisceau"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/f1cee5bc_d261_47bf_99f1_5d7cc79d62b3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://usito.usherbrooke.ca/d%C3%A9finitions/soufflet"
  }, {
    "@value" : "https://www.cnrtl.fr/definition/soufflet"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT004_9"
  }, {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/COMP001_4"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "soufflet"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "instrument utilisé pour souffler de l'air sur un point donné, composé d'une cavité souple, généralement en cuir, fixée entre deux tablettes qui se déplient en faisant entrer l'air et se replient en le chassant"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "soufflet"
  } ],
