    "@value" : "relier"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/fbed6de7_f38f_4ea3_b7f4_66800cae9680",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://usito.usherbrooke.ca/d%C3%A9finitions/%C3%A9rable"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/Plante"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "érable"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "arbre des régions tempérées et froides de l’hémisphère Nord, souvent de grande taille, à feuilles dentées, généralement larges et profondément découpées, dont les fruits sont des samares doubles et dont plusieurs espèces sont cultivées pour leur valeur ornementale"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "érable"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/fd38382d_7787_4fb9_b48b_a1f3009de975",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://usito.usherbrooke.ca/d%C3%A9finitions/pied"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/COMP001_3"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "pied"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "partie d'un objet jouant un rôle de soutien"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "pied"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/instrumentPatient",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Objet élaboré par l’humain » à une ou plusieurs instances de la classe « Entité CRM » subissant ou étant l'objet d'une action découlant de l'usage prévu de l'objet"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "a pour patient"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/patientInstrument"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette relation correspond à la relation instrumentale Instrument-Patient."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "un porte-bébé (Véhicule à propulsion ou à traction humaine) a comme patient (instrumentPatient) un bébé (Personne)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/joint",
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Cette propriété décrit la relation unissant une instance de la classe « Technique ou procédé pour assembler » et au moins deux objets joints par le biais de cette instance."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "joint"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/manipulationObjet",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Chose matérielle élaborée par l'humain » à une instance de la classe « Objet élaboré par l'humain » qui doit être présente afin de permettre ou faciliter l'usage de la seconde"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "permet de manipuler"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/objetManipulation"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette relation correspond à la relation instrumentale Objet utilisé pour sa manipulation-Objet."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "un arc (Arme blanche) permet de manipuler (manipulationObjet) une flèche (Arme blanche)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/materiauComposantMateriauCompose",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Matériau » à une ou plusieurs instances de la même classe, la première instance étant un élément, soit un autre matériau, qui constitue, compose, la seconde"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E57_Material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "constitue"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E57_Material"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/materiauComposeMateriauComposant"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "la fibre de coton (Fibre) constitue (materiauComposantMateriauCompose) un tissu en coton (Tissu)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/materiauComposeMateriauComposant",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Matériau » à une ou plusieurs instances de la même classe, la première instance étant composée, constituée, de la seconde"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E57_Material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "est constitué de"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E57_Material"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "un tissu de coton (Tissu) est composé de (materiauCompoeMateriauComposant) la fibre de coton (Fibre)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/materiauOrganismeVivant",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Matériau » à une instance de la classe « Organisme vivant » de laquelle la matériau est issu, peu importe sa nature"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E57_Material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "provient de"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/MIR0226"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette propriété correspond à la relation complexe Matériau-Organisme vivant."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "la fibre de coton (Fibre) provient de (materiauOrganismeVivant) le cotonnier (Végétal)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/membreEnsemble",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Objet élaboré par l'humain » à une ou plusieurs instances de la même classe, la première instance faisant partie d'un ensemble impliquant une proximité avec les membres et non pas une similarité, chaque membre occupant une fonction spécifique dans l'ensemble"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "fait partie de"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette propriété correspond à la relation partitive Membre-Ensemble."
  }, {
    "@language" : "fr",
    "@value" : "Cette relation possède la propriété de séparabilité, c'est-à-dire que le concept partitif (membre) peut être séparé du concept intégrant (ensemble) sans que l'identité du concept intégrant ne soit affectée."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "un pion (Accessoire ou composant de jeu) fait partie de (membreEnsemble) un jeu de dames (Objet pour le jeu)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/objetAccessoire",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Objet élaboré par l'humain » à une ou plusieurs instances de la classe « Chose matérielle élaborée par l'humain », la première instance étant complétée par la seconde, ou son fonctionnement étant amélioré par la seconde"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "a pour accessoire"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette relation correspond à la relation de contiguïté Objet-Accessoire."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "un téléphone intelligent (Objet pour la télécommunication) a pour accessoire (objetAccessoire) une perche à égoportrait (Objet pour la photographie)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/objetElement",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#TransitiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Objet élaboré par l’humain » à une ou plusieurs instances de la classe « Chose matérielle élaborée par l'humain », la première possédant une structure définie reflétant son découpage en composantes (éléments) entretenant une relation fonctionnelle avec le tout"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "comprend"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette propriété correspond à la relation partitive Objet-Élément."
  }, {
    "@language" : "fr",
    "@value" : "Cette relation possède la propriété de fonctionnalité, c'est-à-dire que le concept partitif (élément) remplit une fonction du concept intégrant (objet)."
  }, {
    "@language" : "fr",
    "@value" : "Cette relation possède la propriété de séparabilité, c'est-à-dire que le concept partitif (élément) peut être séparé du concept intégrant (objet) sans que l'identité du concept intégrant ne soit affectée."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "une tasse (Objet pour le service des aliments) comprend (objetElement) une anse (Caractéristique élaborée par l'humain)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/objetManipulation",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Objet élaboré par l'humain » à une ou plusieurs instances de la classe « Chose matérielle élaborée par l'humain », la première instance nécessitant la présence de la seconde pour permettre ou faciliter son usage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "est manipulé par"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette relation correspond à la relation instrumentale Objet-Objet utilisé pour sa manipulation."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "une flèche (Arme blanche) peut être manipulée par (objetManipulation) un arc (Arme blanche)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/objetProduit",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Objet élaboré par l'humain » à une ou plusieurs instances de la classe « Chose » représentant le résultat issu de l'utilisation prévue de la première instance"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "permet de produire"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E70_Thing"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/produitObjet"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette propriété correspond à la relation d'origine Objet-Produit."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "un appareil photographique (Objet pour la photographie) permet de produire (objetProduit) une photographie (Objet documentaire et Œuvre d'art)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/patientInstrument",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Entité CRM » à une ou plusieurs instances de la classe « Objet élaboré par l'humain », la première instance subissant ou étant l'objet d'une action découlant de l'usage prévu de la seconde"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "est patient de"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette relation correspond à la relation instrumentale Patient-Instrument."
  }, {
    "@language" : "fr",
    "@value" : "un bébé (Personne) est patient de (patientInstrument) un porte-bébé (Véhicule à propulsion ou à traction humaine)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/patientTraitement",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Matériau » à une instance de la classe « Objet élaboré par l'humain », la première instance pouvant être traitée, soit contrôlée, surveillée, récoltée, recueillie, transformée, modifiée ou servie par le biais de l'utilisation prévue de la seconde instance"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E57_Material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "peut être traité par"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/patientInstrument"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/traitementPatient"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/permetDeServir",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Objet pour le service des aliments » à une ou plusieurs instances de la classe « Aliment » qui peut être servie, pour la consommation, par le biais de l'utilisation prévue de la première instance"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT004_4"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "permet de servir"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/MIR0271"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/traitementPatient"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/procedeOuTechniqueResultat",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de la classe « Technique ou Procédé » et une ou plusieurs instances de la classe « Chose » l'ayant produite, c'est-à-dire qu'une technique ou un procédé est mis en oeuvre pour obtenir ce type d'objet"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/MIR0227"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "a pour résultat"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E70_Thing"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/resultatProcedeOuTechnique"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette relation correspond à la relation d'activité Procédé ou technique-Résultat."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "la technique de la broderie (Technique ou procédé d’ouvrage à l’aiguille) a pour résultat (procedeOuTechniqueResultat) une broderie (Œuvre visuelle) résulte de (resultatProcedeOuTechnique)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/produitMateriau",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de la classe « Objet élaboré par l'humain » et une ou plusieurs instances de la classe « Matériau » la constituant, c'est-à-dire que l'objet est un tout rassemblant un ou plusieurs matériaux"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "est constitué de"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E57_Material"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette relation correspond à la relation d'origine Produit-Matériau."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "un bureau (Meuble) est constitué de (produitMateriau) bois (Matière végétale)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/produitObjet",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Chose » à une instance de la classe « Objet élaboré par l'humain », la première instance représentant le résultat issu de l'utilisation prévue de la seconde instance"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E70_Thing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "est produit par"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette propriété correspond à la relation d'origine Produit-Objet."
  }, {
    "@language" : "fr",
    "@value" : "une photographie (Objet documentaire et Œuvre d'art) est produit par (produitObjet) un appareil photographique (Objet pour la photographie)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/produitSupport",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "fr",
    "@value" : "https://usito.usherbrooke.ca/d%C3%A9finitions/support"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de la classe « Objet élaboré par l'humain » et une ou plusieurs instances de la classe « Matériau » étant un élément matériel susceptible de recevoir une œuvre visuelle ou un matériau sur lequel on fait l'impression"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "a pour support"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E57_Material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette relation correspond à la relation complexe Produit-Support."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "une affiche (Support publicitaire) a pour support (produitSupport) le papier cartonné (Papier)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/resultatProcedeOuTechnique",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de la classe « Chose » et une ou plusieurs instances de la classe « Technique ou procédé » la produisant, c'est-à-dire qu'une technique ou un procédé est mis en oeuvre pour obtenir ce type d'objet"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E70_Thing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "résulte de"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/MIR0227"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette relation correspond à la relation d'activité Résultat-Procédé ou technique."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "une broderie (Œuvre visuelle) résulte de (resultatProcedeOuTechnique) la technique de la broderie (Technique ou procédé d’ouvrage à l’aiguille)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/souvenirEntite",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Souvenir » à une instance de la classe « Entité CRM » dont la première instance remet en mémoire, rappelle le souvenir de la seconde instance"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT008_21"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "rappelle ou commémore"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "une assiette commémorative (Souvenir) rappelle ou commémore (souvenirEntite) Élisabeth II (Personne)"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/synonyme",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "synonyme"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/traitementPatient",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "relation unissant une instance de « Objet élaboré par l'humain » à une ou plusieurs instances de la classe « Matériau » qui peut être traitée, soit contrôlée, surveillée, récoltée, recueillie, transformée, modifiée ou servie par le biais de l'usage prévu de la première instance"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "permet de traiter"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E57_Material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/instrumentPatient"
  } ],
  "http://www.w3.org/2004/02/skos/core#editorialNote" : [ {
    "@language" : "fr",
    "@value" : "Cette relation correspond à la relation instrumentale Traitement-Patient."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "un chalumeau (Objet pour le traitement des aliments) permet de traiter (traitementPatient) l'eau d'érable (Matière végétale)"
  } ]
}, {
  "@id" : "https://w3id.org/miron/materiau/14561c34_6364_4e00_b16e_7d3e617d527f",
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8363170/acier-galvanise"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "acier qui a été recouvert d'une couche de zinc afin de former à sa surface un revêtement anticorrosion"
  } ]
}, {
  "@id" : "https://w3id.org/miron/materiau/1ae9b62f_568a_46f9_8a7c_0a025abc9802",
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8362664/acier-inoxydable"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fr",
    "@value" : "acier inox"
  }, {
    "@language" : "fr",
    "@value" : "inox"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "acier allié au chrome et au nickel, pratiquement inaltérable à l'air, résistant à divers agents de corrosion en milieu sec ou humide, à une température élevée ou cryogénique"
  } ]
}, {
  "@id" : "https://w3id.org/miron/objet/6032d27e_ff0b_4c68_859d_38eaf6d0fa17",
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://usito.usherbrooke.ca/d%C3%A9finitions/aiguille"
  }, {
    "@value" : "https://www.cnrtl.fr/definition/aiguille"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fr",
    "@value" : "aiguille à chas"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "tige, généralement métallique, dont l'une des extrémités est effilée, l'autre percée d'un trou (le chas) permettant de passer un fil, utilisée dans les travaux de couture, de broderie, de tapisserie, etc."
  } ]
} ]