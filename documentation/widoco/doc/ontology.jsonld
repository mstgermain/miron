  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "carbone"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "corps simple métalloïde, de numéro atomique 6, très répandu dans la nature soit à l'état pur (diamant, graphite), soit, le plus souvent, combiné avec d'autres corps (gaz carbonique de l'air, charbons, pétrole, etc.)"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "carbone"
  } ]
