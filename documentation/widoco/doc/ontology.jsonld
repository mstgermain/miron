  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "coiffure rigide, de matière et de forme variables, composée d’une calotte et généralement d'un rebord, parfois décorée, servant à protéger la tête contre les éléments ou à compléter la tenue vestimentaire selon les convenances"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
