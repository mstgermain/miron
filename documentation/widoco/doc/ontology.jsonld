    "@value" : "serrure"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "appareil de fermeture comportant un mécanisme se manœuvrant à la main à l'aide d'un accessoire généralement amovible, comme clef, bouton, etc., ou à distance"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
