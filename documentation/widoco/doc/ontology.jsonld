    "@value" : "semoir"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "objet pour l’agriculture"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fr",
    "@value" : "Cette classe comprend les instruments d’ensemencement, d’entretien, de récolte et d’entreposage des produits culturaux, ainsi que les appareils de transformation des aliments destinés aux animaux, mais non aux humains."
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT004_2",
