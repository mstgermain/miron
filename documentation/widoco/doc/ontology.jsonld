    "@value" : "objet récréatif ou sportif"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT009_1",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://nomenclature.info/nom/14351"
  }, {
    "@value" : "https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat9_2"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "objet récréatif créé pour une activité participative, généralement non compétitive, autre qu'un jeu ou un exercice athlétique"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Appareil récréatif"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT009"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fr",
    "@value" : "appareils récréatifs"
  }, {
    "@language" : "fr",
    "@value" : "équipement récréosportif"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fr",
    "@value" : "billard électrique;glissoire;balançoire;carrousel"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "appareil récréatif"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fr",
    "@value" : "Cette classse comprend l'équipement de divertissement, que cet équipement soit propriété publique ou privée et qu'il y ait ou non des frais reliés à son utilisation."
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT009_2",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://nomenclature.info/nom/14709"
  }, {
    "@value" : "https://usito.usherbrooke.ca/d%C3%A9finitions/jouet"
  }, {
    "@value" : "https://www.cnrtl.fr/definition/jouet"
  }, {
    "@value" : "https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat9_5"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "objet récréatif créé pour s'amuser, généralement utilisé par les enfants"
  } ],
