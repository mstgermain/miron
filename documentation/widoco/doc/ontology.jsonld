  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "assiette, plus petite qu'une assiette plate, servant à mettre ou recevoir de la nourriture à table, au repas du midi"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Assiette à déjeuner"
  } ],
