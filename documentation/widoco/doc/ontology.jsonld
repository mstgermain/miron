  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "arme blanche et arme de de jet composée d'un fût de bois muni d'une pointe aiguë à une extrémité, d'un empennage à l'autre, et que l'on lance principalement à l'aide d'un arc"
  } ],
