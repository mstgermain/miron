  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "scie munie d'une lame de coupe dentée sur une rive, disposée dans le prolongement du manche, effectuant un mouvement rectiligne alternatif à l'horizontale ou à la verticale, servant principalement aux coupes de dégrossissage et aux travaux de démolition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Scie alternative"
  } ],
