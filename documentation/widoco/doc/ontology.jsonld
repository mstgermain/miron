    "@value" : "cotonnier"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "plante originaire des régions tropicales et subtropicales, voisine de l’hibiscus, dont on cultive certaines espèces pour leurs fruits à graines oléagineuses qui fournissent la fibre de coton, destinée à la fabrication textile, et une huile végétale, utilisée à des fins alimentaires, cosmétiques ou industrielles"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "cotonnier"
  } ]
