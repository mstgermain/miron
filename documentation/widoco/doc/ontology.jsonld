    "@language" : "fr",
    "@value" : "orignal"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fr",
    "@value" : "cervidé herbivore de grande taille des régions nordiques de l'Amérique et de l'Eurasie, à pelage brun noirâtre, caractérisé par un gros museau recourbé, un appendice pendant sous la gorge et de hautes épaules surmontées d'une bosse"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "orginal"
  } ],
  "https://stgermain.ebsi.umontreal.ca/miron/synonyme" : [ {
    "@language" : "fr",
    "@value" : "élan d'Amérique"
  } ]
