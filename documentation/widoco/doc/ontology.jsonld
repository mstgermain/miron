    "@language" : "fr",
    "@value" : "armement, sciences et technologies"
  }, {
    "@language" : "fr",
    "@value" : "outillage et équipement pour les sciences et la technologie"
  } ],
  "http://www.w3.org/2004/02/skos/core#hiddenLabel" : [ {
    "@language" : "fr",
    "@value" : "catégorie 05"
  }, {
    "@language" : "fr",
    "@value" : "catégorie 5"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "objet pour les sciences ou la technologie"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fr",
    "@value" : "Les objets pour les sciences ou la technologie visent généralement à augmenter ou à documenter les connaissances sur le monde qui nous entoure ou pour exprimer ces connaissances. Les sous-classes de cette classe sont apparentées en vertu du fait qu'elles comprennent des objets élaborés par l'humain créés pour exploiter un domaine particulier de connaissances. Elles sont donc basées sur les connaissances plutôt que les matériaux."
  } ]
