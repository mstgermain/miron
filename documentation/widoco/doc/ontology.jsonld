  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "procédé ou technique de création d'images permettant ou facilitant la création de photographies, soit des images durables obtenues en exposant, généralement pendant une très courte durée, une surface photosensible à la lumière focalisée par un objectif"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Procédé ou technique photographique"
  } ],
