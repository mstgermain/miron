    "@value" : "arts visuels"
  } ],
  "http://www.w3.org/2004/02/skos/core#hiddenLabel" : [ {
    "@language" : "fr",
    "@value" : "oeuvre visuelle"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "œuvre visuelle"
  } ]
}, {
  "@id" : "https://stgermain.ebsi.umontreal.ca/miron/CAT009",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "https://nomenclature.info/nom/14135"
  }, {
    "@value" : "https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#Categorie9"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "objet élaboré par l'humain créé pour être utilisé comme jouet, pour le jeu, les activités sportives, les jeux de hasard ou le divertissement du public"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Objet récréatif ou sportif"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fr",
    "@value" : "objets récréatifs"
  }, {
    "@language" : "fr",
    "@value" : "sport et divertissement"
  } ],
  "http://www.w3.org/2004/02/skos/core#hiddenLabel" : [ {
    "@language" : "fr",
    "@value" : "catégorie 09"
  }, {
    "@language" : "fr",
    "@value" : "catégorie 9"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
