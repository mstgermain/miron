  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "vêtement d'extérieur ample de longueur variable, dépourvu de manches et d'emmanchures, couvrant le corps et les bras, fermé au milieu du devant, sur toute sa longueur ou seulement à l’encolure, comportant parfois un capuchon, un col et des passe-bras, servant à protéger contre les intempéries et le froid"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Cape"
