        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005_72"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/fl%C3%A8che</terms:source>
        <rdfs:comment xml:lang="fr">arme blanche et arme de de jet composée d&apos;un fût de bois muni d&apos;une pointe aiguë à une extrémité, d&apos;un empennage à l&apos;autre, et que l&apos;on lance principalement à l&apos;aide d&apos;un arc</rdfs:comment>
        <rdfs:label xml:lang="fr">Flèche</rdfs:label>
        <skos:prefLabel xml:lang="fr">flèche</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR152 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR152">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005_4"/>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT009_2"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/02ee4f75_f7a9_4182_b176_9e7f046ffb59"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/06a69674_ea68_461e_b8fb_e439c59d40b5"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/75c5da1a_5bae_49bc_93bc_0ffcf717cba6"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8418289/moulin-a-vent</terms:source>
        <rdfs:comment xml:lang="fr">jouet ou objet pour la météorologie fait de pales légères, fixées en leur centre par une tige liée à un bâtonnet, et qui tournent au vent</rdfs:comment>
        <rdfs:label xml:lang="fr">Virevent</rdfs:label>
        <skos:prefLabel xml:lang="fr">virevent</skos:prefLabel>
        <synonyme xml:lang="fr">moulin à vent</synonyme>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR168 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR168">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_41"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                        <owl:someValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0082"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                        <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/ea03b54b_2c7f_4691_89c8_62108616b94f"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/accessoireObjet"/>
                <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_422"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/anche</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/anche</terms:source>
        <rdfs:comment xml:lang="fr">fine languette de roseau ou de métal placée sur certains instruments à vent et dont la vibration permet de produire le son</rdfs:comment>
        <rdfs:label xml:lang="fr">Anche</rdfs:label>
        <skos:prefLabel xml:lang="fr">anche</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR201 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR201">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT009_1"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/poids</terms:source>
        <rdfs:comment xml:lang="fr">appareil récréatif composé d&apos;un objet lourd, servant à être soulevé pour l’entraînement musculaire</rdfs:comment>
        <rdfs:label xml:lang="fr">Poids</rdfs:label>
        <skos:prefLabel xml:lang="fr">poids</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR211 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR211">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT009_4"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/8b80ed0f_0e0f_487c_aef2_c469fbe2987f"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/resultatProcedeOuTechnique"/>
                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/2871057a_0bd0_448e_804c_3c9182bb67e6"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/casse-t%C3%Aate</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8871815/casse-tete</terms:source>
        <rdfs:comment xml:lang="fr">jeu de patience qui consiste à reconstituer une image en agençant, en emboîtant, correctement des pièces cartonnées, découpées de manière irrégulière</rdfs:comment>
        <rdfs:label xml:lang="fr">Casse-tête (jeu)</rdfs:label>
        <skos:prefLabel xml:lang="fr">casse-tête</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/Mammifere -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/Mammifere">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Animal"/>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8980247/mammiferes</terms:source>
        <rdfs:comment xml:lang="fr">animal appartenant à l&apos;embranchement des vertébrés, dont les individus se caractérisent par la présence de glandes mammaires, d&apos;osselets de l&apos;ouïe, d&apos;une mâchoire inférieure s&apos;articulant directement avec le crâne et de poils sur la peau à un moment ou un autre de leur développement</rdfs:comment>
        <rdfs:label xml:lang="fr">Mammifère</rdfs:label>
        <skos:prefLabel xml:lang="fr">mammifère</skos:prefLabel>
        <synonyme xml:lang="fr">mammalia</synonyme>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/Oiseau -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/Oiseau">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Animal"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/oiseau</terms:source>
        <rdfs:comment xml:lang="fr">animal vertébré, le plus souvent de petite taille, à peau recouverte de plumes, qui est pourvu d’un bec corné, de deux pattes écailleuses griffues et de deux ailes généralement bien adaptées au vol, dont la femelle pond des œufs et qui, selon les espèces, peut émettre des chants plus ou moins développés et présenter des coloris de plumage variables selon l’âge, le sexe ou la saison</rdfs:comment>
        <rdfs:label xml:lang="fr">Oiseau</rdfs:label>
        <skos:prefLabel xml:lang="fr">oiseau</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/OuvrageAiguille -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/OuvrageAiguille">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0227"/>
        <terms:source>http://vocab.getty.edu/page/aat/300053652</terms:source>
        <rdfs:comment xml:lang="fr">procédé ou technique réalisé avec une aiguille et du fil</rdfs:comment>
        <rdfs:label xml:lang="fr">Procédé ou technique d’ouvrage à l’aiguille</rdfs:label>
        <skos:prefLabel xml:lang="fr">procédé ou technique d’ouvrage à l’aiguille</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/Photographie -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/Photographie">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CreationImages"/>
        <terms:source>http://vocab.getty.edu/page/aat/300054225</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/17075837/photographie</terms:source>
        <rdfs:comment xml:lang="fr">procédé ou technique de création d&apos;images permettant ou facilitant la création de photographies, soit des images durables obtenues en exposant, généralement pendant une très courte durée, une surface photosensible à la lumière focalisée par un objectif</rdfs:comment>
        <rdfs:label xml:lang="fr">Procédé ou technique photographique</rdfs:label>
        <skos:prefLabel xml:lang="fr">technique ou procédé photographique</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/Plante -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/Plante">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0226"/>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8363161/vegetal</terms:source>
        <rdfs:comment xml:lang="fr">organisme vivant dont les cellules sont constituées d&apos;une paroi cellulaire végétale, de vacuoles et de plastes</rdfs:comment>
        <rdfs:label xml:lang="fr">Végétal</rdfs:label>
        <skos:prefLabel xml:lang="fr">végétal</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/Sculpture -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/Sculpture">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0227"/>
        <terms:source>http://vocab.getty.edu/page/aat/300053618</terms:source>
        <rdfs:comment xml:lang="fr">procédé ou technique permettant de concevoir des objets tridimensionnels avec des matériaux malléables ou durs</rdfs:comment>
        <rdfs:label xml:lang="fr">Procédé ou technique de sculpture</rdfs:label>
        <skos:prefLabel xml:lang="fr">procédé ou technique de sculpture</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/Soustraction -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/Soustraction">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0227"/>
        <terms:source>http://vocab.getty.edu/page/aat/300229471</terms:source>
        <rdfs:comment xml:lang="fr">procédé ou technique permettant de retirer, de retrancher un ou des éléments à d&apos;autres</rdfs:comment>
        <rdfs:label xml:lang="fr">Procédé ou technique de soustraction</rdfs:label>
        <skos:prefLabel xml:lang="fr">procédé ou technique de soustraction</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/TYP003_12 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/TYP003_12">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0197"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                <owl:allValuesFrom rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>http://vocab.getty.edu/page/aat/300014058</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/17032424/fibres-synthetiques</terms:source>
        <rdfs:comment xml:lang="fr">fibre élaborée industriellement, à partir de substances chimiques, se différenciant ainsi des matériaux apparaissant naturellement sous forme fibreuse</rdfs:comment>
        <rdfs:label xml:lang="fr">Fibre synthétique</rdfs:label>
        <skos:prefLabel xml:lang="fr">fibre synthétique</skos:prefLabel>
        <synonyme xml:lang="fr">fibre manufacturée</synonyme>
    </owl:Class>
    


