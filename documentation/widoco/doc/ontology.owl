        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetManipulation"/>
                <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0142"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/canot</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/2079485/canot</terms:source>
        <rdfs:comment xml:lang="fr">embarcation d&apos;origine autochtone légère non pontée, de forme longiligne, effilée aux deux extrémités et propulsée à la pagaie simple, en position assise ou agenouillée</rdfs:comment>
        <rdfs:label xml:lang="fr">Canot</rdfs:label>
        <skos:prefLabel xml:lang="fr">canot</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0028 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0028">
