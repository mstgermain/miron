                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                        <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/02712e9b_d956_4a33_9cdb_ac6cf91e3cab"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_422"/>
        <terms:source>https://nomenclature.info/nom/10708</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/17058634/accordéon</terms:source>
        <rdfs:comment xml:lang="fr">instrument à vent composé de deux boîtiers rectangulaires en bois ou en métal reliés par un soufflet extensible en cuir, chacun munis à l&apos;intérieur de plusieurs anches en métal reliées à l&apos;extérieur à un clavier à touches et à boutons, généralement avec des bretelles en cuir, et servant à produire des sons et des accords par l&apos;action de l&apos;air du soufflet et la pression des touches ou des boutons sur les anches libres</rdfs:comment>
        <rdfs:label xml:lang="fr">Accordéon</rdfs:label>
        <skos:prefLabel xml:lang="fr">accordéon</skos:prefLabel>
    </owl:Class>
    


