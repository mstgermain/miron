        <terms:source>https://nomenclature.info/nom/2272</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/chapeau</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/2073696/chapeau</terms:source>
        <rdfs:comment xml:lang="fr">coiffure rigide, de matière et de forme variables, composée d’une calotte et généralement d&apos;un rebord, parfois décorée, servant à protéger la tête contre les éléments ou à compléter la tenue vestimentaire selon les convenances</rdfs:comment>
        <rdfs:label xml:lang="fr">Chapeau</rdfs:label>
        <skos:prefLabel xml:lang="fr">chapeau</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0037 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0037">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008_311"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
                        <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/216031b2_8732_463c_8cac_3160c1d22d60"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
                        <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/8eecd701_4628_480e_bac4_a6c5d492146a"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
