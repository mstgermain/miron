     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:miron="https://stgermain.ebsi.umontreal.ca/miron/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:cidoc-crm="http://www.cidoc-crm.org/cidoc-crm/">
    <owl:Ontology rdf:about="https://stgermain.ebsi.umontreal.ca/miron/">
        <owl:versionIRI rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/1.1.0"/>
        <owl:imports rdf:resource="http://www.cidoc-crm.org/cidoc-crm/"/>
        <owl:imports rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <terms:created>2024/11/08</terms:created>
        <terms:creator rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://orcid.org/0000-0001-7426-1690</terms:creator>
        <terms:creator>Marielle St-Germain</terms:creator>
        <terms:license>https://creativecommons.org/licenses/by/4.0/</terms:license>
        <terms:modified>2026/04/23</terms:modified>
        <terms:title xml:lang="fr">MIRON - Modélisation pour l&apos;Interopérabilité, le Repérage et la réutilisatiON de données du patrimoine culturel québécois</terms:title>
        <vann:preferredNamespacePrefix>miron</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://stgermain.ebsi.umontreal.ca/miron/</vann:preferredNamespaceUri>
        <owl:priorVersion>1.0.0</owl:priorVersion>
        <owl:versionInfo>1.1.0</owl:versionInfo>
    </owl:Ontology>
    


