        <rdfs:comment xml:lang="fr">tube en bois ou en métal effilé à une extrémité, parfois muni d&apos;un crochet en métal, servant à faciliter l&apos;écoulement de l&apos;eau d&apos;érable de l&apos;entaille d&apos;un érable à sucre à un seau ou à une tubulure d&apos;un système de collecte</rdfs:comment>
        <rdfs:label xml:lang="fr">Chalumeau</rdfs:label>
        <skos:prefLabel xml:lang="fr">chalumeau</skos:prefLabel>
        <synonyme xml:lang="fr">chalumeau à sève</synonyme>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0035 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0035">
