    <!-- https://stgermain.ebsi.umontreal.ca/miron/9705c0d2_2b95_403e_bf7e_fbe9fe1feba2 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/9705c0d2_2b95_403e_bf7e_fbe9fe1feba2">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Plante"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/roseau</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/roseau</terms:source>
        <rdfs:label xml:lang="fr">roseau (végétal)</rdfs:label>
        <skos:definition xml:lang="fr">Plante herbacée, souvent de grande taille et de type graminée, à feuilles étroites et élancées, à tige droite et robuste souvent remplie de moëlle, à fleurs disposées en panicule ou groupées en deux épis supersposés dont l&apos;inférieur se développe sous la forme d&apos;un cylindre brun foncé velouté, qui croît dans les marais et les eaux peu profondes</skos:definition>
        <skos:prefLabel xml:lang="fr">roseau</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/9816503e_8680_4f2a_8eb1_75e87c5cb7fb -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/9816503e_8680_4f2a_8eb1_75e87c5cb7fb">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/COMP001_5"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/tige</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/tige</terms:source>
        <rdfs:label xml:lang="fr">tige (composant vestimentaire)</rdfs:label>
        <skos:definition xml:lang="fr">partie d&apos;une chaussure, d&apos;une botte, qui couvre le dessus du pied, la cheville et éventuellement la jambe</skos:definition>
        <skos:prefLabel xml:lang="fr">tige</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/9870463b_50e9_4800_a94f_7cd119f43859 -->


