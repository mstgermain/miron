    <!-- https://stgermain.ebsi.umontreal.ca/miron/a0953ff7_b1ce_49a7_b182_4146d94507a5 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/a0953ff7_b1ce_49a7_b182_4146d94507a5">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0259"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/aspersion</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/aspersion</terms:source>
        <rdfs:label xml:lang="fr">aspersion</rdfs:label>
        <skos:definition xml:lang="fr">rite religieux consistant à asperger d&apos;eau bénite</skos:definition>
        <skos:prefLabel xml:lang="fr">aspersion</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/a424e871_1a53_4349_baa6_1c84de566cfe -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/a424e871_1a53_4349_baa6_1c84de566cfe">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Mammifere"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/cheval</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8403776/cheval</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/cheval</terms:source>
        <rdfs:label xml:lang="fr">cheval</rdfs:label>
        <skos:definition xml:lang="fr">mammifère ongulé appartenant à la famille des équidés, souvent de grande taille et à crinière longue et souple, à queue composée de longs crins dès la racine, qui a été domestiqué notamment comme animal de selle et de trait</skos:definition>
        <skos:hiddenLabel>equus caballus</skos:hiddenLabel>
        <skos:hiddenLabel>equus ferus caballus</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">cheval</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/a7244508_ce48_4c34_8ad6_ea6775f10bd3 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/a7244508_ce48_4c34_8ad6_ea6775f10bd3">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0233"/>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8981053/silicate</terms:source>
        <rdfs:label xml:lang="fr">silicate</rdfs:label>
        <skos:definition xml:lang="fr">minéral tétraédrique formé essentiellement de silicium et d&apos;oxygène</skos:definition>
        <skos:prefLabel xml:lang="fr">silicate</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/a8cc4c33_a578_4998_a039_735c977286e0 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/a8cc4c33_a578_4998_a039_735c977286e0">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004_9"/>
        <objetElement rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/cd9aab25_c12c_4c7f_a36a_4a240665cf6d"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/cadran</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/cadran</terms:source>
        <rdfs:label xml:lang="fr">cadran</rdfs:label>
        <skos:definition xml:lang="fr">surface portant des divisions ou des repères devant lesquels se déplacent une ou plusieurs aiguilles, servant à indiquer les variations d&apos;une grandeur (pression, vitesse, etc.), soit un système de repérage</skos:definition>
        <skos:prefLabel xml:lang="fr">cadran</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/a9705c9a_a16f_43d8_82a8_316a5e42d8b9 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/a9705c9a_a16f_43d8_82a8_316a5e42d8b9">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Mammifere"/>
        <terms:source>https://www.cnrtl.fr/definition/vache</terms:source>
        <rdfs:label xml:lang="fr">vache</rdfs:label>
        <skos:definition xml:lang="fr">bovidé domestique à cornes, femelle du taureau élevée principalement pour ses qualités de reproductrice et de laitière</skos:definition>
        <skos:prefLabel xml:lang="fr">vache</skos:prefLabel>
        <synonyme xml:lang="fr">bos taurus</synonyme>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/adb852e6_0e25_4ffd_b72d_53e16f5fa578 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/adb852e6_0e25_4ffd_b72d_53e16f5fa578">
