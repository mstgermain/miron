        <terms:source>https://www.cnrtl.fr/definition/pistolet</terms:source>
        <rdfs:comment>arme à feu portative, à canon court, qui se tient d&apos;une seule main</rdfs:comment>
        <rdfs:label xml:lang="fr">Pistolet</rdfs:label>
        <skos:prefLabel xml:lang="fr">pistolet</skos:prefLabel>
    </owl:Class>
    


