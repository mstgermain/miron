                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/b3dba423_02a4_4080_bd5f_7a2c5ebbaa65"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
