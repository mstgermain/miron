        <terms:source>http://vocab.getty.edu/page/aat/300010900</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/m%C3%A9tal_1</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8363003/metal</terms:source>
        <rdfs:comment xml:lang="fr">élément chimique brillant, ductile, malléable, généralement bon conducteur électrique et thermique, libérant des cations et donnant des oxydes généralement basiques en se combinant avec l&apos;oxygène</rdfs:comment>
        <rdfs:label xml:lang="fr">Métal</rdfs:label>
        <skos:prefLabel xml:lang="fr">métal</skos:prefLabel>
    </owl:Class>
    


