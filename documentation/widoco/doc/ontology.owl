        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/porcelaine</terms:source>
        <rdfs:comment xml:lang="fr">céramique fine, dure et translucide obtenue par la cuisson d&apos;une pâte composée de kaolin pur et de feldspath</rdfs:comment>
        <rdfs:label xml:lang="fr">Porcelaine</rdfs:label>
        <skos:prefLabel xml:lang="fr">porcelaine</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0116 -->


