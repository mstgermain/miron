            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>http://data.culture.fr/thesaurus/resource/ark:/67717/T69-1114</terms:source>
        <terms:source>https://nomenclature.info/nom/13093</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la cérémonie et le culte créé pour être utilisé dans un culte religieux public ou des cérémonies spirituelles</rdfs:comment>
        <rdfs:comment xml:lang="fr">objet religieux lié à l&apos;exercice ou à la pratique du culte catholique</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet du culte catholique</rdfs:label>
        <rdfs:label xml:lang="fr">Objet religieux</rdfs:label>
        <skos:prefLabel xml:lang="fr">objet du culte catholique</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">objet religieux</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT008_311 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT008_311">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008_31"/>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008_5"/>
