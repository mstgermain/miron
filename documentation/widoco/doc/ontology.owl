        <terms:source>https://www.cnrtl.fr/definition/assiette</terms:source>
        <rdfs:comment xml:lang="fr">pièce de vaisselle individuelle en céramique, en métal, en verre ou en bois, servant à mettre ou recevoir les aliments à table</rdfs:comment>
        <rdfs:label xml:lang="fr">Assiette</rdfs:label>
        <skos:prefLabel xml:lang="fr">assiette</skos:prefLabel>
