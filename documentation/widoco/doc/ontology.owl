        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Mammifere"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/boeuf</terms:source>
        <rdfs:label xml:lang="fr">bœuf</rdfs:label>
        <skos:definition xml:lang="fr">grand bovidé à corps massif, à tête large et à cornes arquées, dont on élève diverses espèces pour la production de viande, de cuir et de lait</skos:definition>
        <skos:hiddenLabel xml:lang="fr">boeuf</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">bœuf</skos:prefLabel>
        <synonyme xml:lang="fr">bos taurus</synonyme>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/ea92665c_9df4_4970_8c09_083b096716a6 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/ea92665c_9df4_4970_8c09_083b096716a6">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_5"/>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/3296041/surface-photosensible</terms:source>
        <rdfs:label xml:lang="fr">surface photosensible</rdfs:label>
        <skos:definition xml:lang="fr">surface qui réagit à l&apos;exposition d&apos;un rayonnement électromagnétique et qui permet d&apos;enregistrer et de reconstituer une image</skos:definition>
        <skos:prefLabel xml:lang="fr">surface photosensible</skos:prefLabel>
        <synonyme xml:lang="fr">surface sensible</synonyme>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/ee1866cf_de4f_4355_b37b_54f1db265c20 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/ee1866cf_de4f_4355_b37b_54f1db265c20">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0255"/>
        <terms:source>https://terminology.collectionstrust.org.uk/British-Museum-materials/mathesg.htm#836</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/or_1</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8872591/or</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/or</terms:source>
        <rdfs:label xml:lang="fr">or</rdfs:label>
        <skos:definition xml:lang="fr">métal précieux, jaune brillant, très dense, très malléable et très ductile, inaltérable à l’air, à l’eau et aux acides, utilisé notamment en bijouterie, en orfèvrerie et en dentisterie</skos:definition>
        <skos:prefLabel xml:lang="fr">or</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/efec659f_3e58_4282_8ad4_74cff50136ba -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/efec659f_3e58_4282_8ad4_74cff50136ba">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/COMP001_3"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/rebord</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/rebord</terms:source>
        <rdfs:label xml:lang="fr">rebord</rdfs:label>
        <skos:definition xml:lang="fr">partie relevée en saillie qui forme le bord</skos:definition>
        <skos:prefLabel xml:lang="fr">rebord</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/effb3826_a168_41e8_8f15_c848f068a076 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/effb3826_a168_41e8_8f15_c848f068a076">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0256"/>
        <terms:source>http://vocab.getty.edu/page/aat/300014502</terms:source>
        <rdfs:label xml:lang="fr">vinyle</rdfs:label>
        <skos:definition xml:lang="fr">plastique dérivé du chlorure de vinyle, de l&apos;acétate de vinyle ou du chlorure de vinylidène</skos:definition>
        <skos:prefLabel xml:lang="fr">vinyle</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Le terme est couramment utilisé pour désigner tous les polymères et copolymères dont le chlorure de vinyle est un constituant.</skos:scopeNote>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/f0493811_5856_4437_ae58_64ffe4f36d7b -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/f0493811_5856_4437_ae58_64ffe4f36d7b">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/COMP001_3"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/faisceau</terms:source>
        <rdfs:label xml:lang="fr">faisceau</rdfs:label>
        <skos:definition xml:lang="fr">assemblage de choses de même nature et de forme allongée, liées ensemble ou qui convergent à une de leur extrémité</skos:definition>
        <skos:prefLabel xml:lang="fr">faisceau</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/f1cee5bc_d261_47bf_99f1_5d7cc79d62b3 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/f1cee5bc_d261_47bf_99f1_5d7cc79d62b3">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004_9"/>
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/COMP001_4"/>
        <produitMateriau rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/02712e9b_d956_4a33_9cdb_ac6cf91e3cab"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/soufflet</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/soufflet</terms:source>
        <rdfs:label xml:lang="en">soufflet</rdfs:label>
        <skos:definition xml:lang="fr">instrument utilisé pour souffler de l&apos;air sur un point donné, composé d&apos;une cavité souple, généralement en cuir, fixée entre deux tablettes qui se déplient en faisant entrer l&apos;air et se replient en le chassant</skos:definition>
        <skos:prefLabel xml:lang="fr">soufflet</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/f37c006e_72a6_4015_86da_412275abbd98 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/f37c006e_72a6_4015_86da_412275abbd98">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0260"/>
        <terms:source>https://www.cnrtl.fr/definition/eucharistie</terms:source>
        <rdfs:label xml:lang="fr">eucharistie</rdfs:label>
        <skos:definition xml:lang="fr">sacrement contenant le corps, le sang et la divinité du Christ au terme de la transsubstantiation du pain et du vin, renouvelant rituellement en action de grâce le sacrifice du Christ et constituant la nourriture des fidèles et le symbole de leur unité</skos:definition>
        <skos:prefLabel xml:lang="fr">eucharistie</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/f4e40103_2809_47fa_974c_3aaa1ceffba2 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/f4e40103_2809_47fa_974c_3aaa1ceffba2">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0233"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/carbone</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/carbone</terms:source>
        <rdfs:label xml:lang="fr">carbone</rdfs:label>
        <skos:definition xml:lang="fr">corps simple métalloïde, de numéro atomique 6, très répandu dans la nature soit à l&apos;état pur (diamant, graphite), soit, le plus souvent, combiné avec d&apos;autres corps (gaz carbonique de l&apos;air, charbons, pétrole, etc.)</skos:definition>
        <skos:prefLabel xml:lang="fr">carbone</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/f5fc4d7d_967b_433a_8df8_80f5b8715d03 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/f5fc4d7d_967b_433a_8df8_80f5b8715d03">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0255"/>
        <terms:source>http://vocab.getty.edu/page/aat/300011029</terms:source>
        <terms:source>https://terminology.collectionstrust.org.uk/British-Museum-materials/mathess.htm#1782</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/17026464/argent</terms:source>
        <rdfs:label xml:lang="fr">argent</rdfs:label>
        <skos:definition xml:lang="fr">métal précieux, blanc, brillant, très ductile et malléable, inoxydable</skos:definition>
        <skos:prefLabel xml:lang="fr">argent</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/f9068b15_bfda_4089_9ac6_83d71c6d9b48 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/f9068b15_bfda_4089_9ac6_83d71c6d9b48">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005_5"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/serrure</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/17027900/serrure</terms:source>
        <rdfs:label xml:lang="fr">serrure</rdfs:label>
        <skos:definition xml:lang="fr">appareil de fermeture comportant un mécanisme se manœuvrant à la main à l&apos;aide d&apos;un accessoire généralement amovible, comme clef, bouton, etc., ou à distance</skos:definition>
        <skos:prefLabel xml:lang="fr">serrure</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/fad7d1a9_a90c_45ba_94c0_e9e300a45b2f -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/fad7d1a9_a90c_45ba_94c0_e9e300a45b2f">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0082"/>
        <terms:source>https://terminology.collectionstrust.org.uk/British-Museum-materials/mathest.htm#1923</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/%C3%A9tain</terms:source>
        <rdfs:label xml:lang="fr">étain</rdfs:label>
        <skos:definition xml:lang="fr">métal gris blanc, ductile, malléable, le plus fusible de tous les métaux usuels, qui s&apos;effrite aux très basses températures</skos:definition>
        <skos:prefLabel xml:lang="fr">étain</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/faef69b7_04b1_47a0_ada8_fed3aed70985 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/faef69b7_04b1_47a0_ada8_fed3aed70985">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0229"/>
        <materiauComposantMateriauCompose rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/9641af62_aff2_4c48_acc6_835d9314d9e7"/>
        <materiauOrganismeVivant rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/0c649efc_ec12_48d7_badb_4f05ca05cc83"/>
        <terms:source>http://vocab.getty.edu/page/aat/300183670</terms:source>
        <terms:source>https://terminology.collectionstrust.org.uk/British-Museum-materials/mathesc.htm#544</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/coton</terms:source>
