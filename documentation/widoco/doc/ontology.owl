        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/fd38382d_7787_4fb9_b48b_a1f3009de975"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/02ee4f75_f7a9_4182_b176_9e7f046ffb59"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/chandelier</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/chandelier</terms:source>
        <rdfs:comment xml:lang="fr">ustensile généralement constitué d&apos;un pied, d&apos;une tige pouvant se diviser en plusieurs branches, d&apos;une bobèche ou d&apos;une cuvette surmontée d&apos;une pointe, servant de support aux chandelles, aux cierges et aux bougies</rdfs:comment>
        <rdfs:label xml:lang="fr">Chandelier</rdfs:label>
        <skos:prefLabel xml:lang="fr">chandelier</skos:prefLabel>
        <synonyme xml:lang="fr">flambeau</synonyme>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0036 -->


