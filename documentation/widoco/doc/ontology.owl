        <terms:source>https://nomenclature.info/nom/12956</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationarts/classificationartsdefinition.htm#souscat1_9</terms:source>
        <rdfs:comment xml:lang="fr">œuvre visuelle tridimensionnelle où des images et des formes sont produites en sculptant ou en gravant une matière dure, en façonnant ou en moulant une matière malléable (qui durcit habituellement par la suite) ou en assemblant diverses parties pour fabriquer un objet tridimensionnel, de taille moyenne ou grande, faits de pierre, de bois, de bronze ou d’un autre métal</rdfs:comment>
        <rdfs:label xml:lang="fr">Sculpture</rdfs:label>
        <skos:prefLabel xml:lang="fr">sculpture</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0142 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0142">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0270"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/pagaie</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8421881/pagaie</terms:source>
        <rdfs:comment xml:lang="fr">aviron court, terminé en large pelle à une extrémité, qui n’est pas fixé à l’embarcation</rdfs:comment>
        <rdfs:label xml:lang="fr">Pagaie simple</rdfs:label>
        <skos:prefLabel xml:lang="fr">pagaie simple</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0147 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0147">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005_73"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/79763ed0_de8c_421b_8ff4_a54dfa31e557"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/massue</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/massue</terms:source>
        <rdfs:comment xml:lang="fr">arme contondante constituée d&apos;un bâton noueux, gros et court, dont la tête renflée sert à frapper avec une grande violence, à assommer</rdfs:comment>
        <rdfs:label xml:lang="fr">Massue</rdfs:label>
        <skos:prefLabel xml:lang="fr">massue</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0148 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0148">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0236"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/pierre</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/pierre</terms:source>
        <rdfs:comment xml:lang="fr">matière minérale solide plus ou moins dure qu&apos;on rencontre en masses compactes à la surface et à l&apos;intérieur du sol</rdfs:comment>
        <rdfs:label xml:lang="fr">Pierre</rdfs:label>
        <skos:prefLabel xml:lang="fr">pierre</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0149 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0149">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT003_31"/>
