        <rdfs:label xml:lang="fr">Procédé ou technique de construction textile</rdfs:label>
        <skos:prefLabel xml:lang="fr">procédé ou technique de construction textile</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CreationImages -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CreationImages">
