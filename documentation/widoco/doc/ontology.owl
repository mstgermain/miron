        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8433964/appeau</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la pêche ou le piégeage à vent ou à friction avec lequel on imite le cri des oiseaux et des mammifères pour les attirer</rdfs:comment>
        <rdfs:label xml:lang="fr">Appeau</rdfs:label>
        <skos:prefLabel xml:lang="fr">appeau</skos:prefLabel>
    </owl:Class>
    


