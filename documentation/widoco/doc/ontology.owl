                        <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/952bf3c3_3caa_43c0_a72d_a2df4b39de0f"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004_2"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/pinceau</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/pinceau</terms:source>
        <rdfs:comment xml:lang="fr">instrument composé d&apos;un faisceau, souvent effilé, de poils ou de fibres souples serrés par une virole au bout d&apos;un manche, servant à étendre en couche mince une substance liquide ou semi-liquide sur un support et, ainsi, peindre, vernir, coller, etc.</rdfs:comment>
        <rdfs:label xml:lang="fr">Pinceau</rdfs:label>
        <skos:prefLabel xml:lang="fr">pinceau</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0065 -->


