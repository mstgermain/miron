        <rdfs:label xml:lang="fr">Assiette à dessert</rdfs:label>
        <skos:hiddenLabel xml:lang="fr">assiette à desserts</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">assiette à dessert</skos:prefLabel>
    </owl:Class>
    


