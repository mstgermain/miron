        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8375461/console-de-jeu</terms:source>
        <rdfs:comment xml:lang="fr">matériel informatique autonome ou non et d&apos;apparence diverse, servant à l&apos;exécution de jeux vidéo</rdfs:comment>
        <rdfs:label xml:lang="fr">Console de jeu</rdfs:label>
        <skos:prefLabel xml:lang="fr">console de jeu</skos:prefLabel>
        <synonyme xml:lang="fr">console de jeu vidéo</synonyme>
    </owl:Class>
    


