        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/manteau</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/manteau</terms:source>
        <rdfs:comment xml:lang="fr">vêtement de dessus généralement long, ample, à manches longues et fermé sur le devant, fait de tissu ou d&apos;autres matériaux, servant à être porté sur tout le corps afin de le protéger du froid ou des intempéries</rdfs:comment>
        <rdfs:label xml:lang="fr">Manteau</rdfs:label>
        <skos:prefLabel xml:lang="fr">manteau</skos:prefLabel>
    </owl:Class>
    


