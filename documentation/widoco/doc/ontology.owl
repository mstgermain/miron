    <!-- https://stgermain.ebsi.umontreal.ca/miron/94a239dd_a821_4439_a00d_27bd7cffdcce -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/94a239dd_a821_4439_a00d_27bd7cffdcce">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Mammifere"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/orignal</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8871650/orignal</terms:source>
        <rdfs:label xml:lang="fr">orignal</rdfs:label>
        <skos:definition xml:lang="fr">cervidé herbivore de grande taille des régions nordiques de l&apos;Amérique et de l&apos;Eurasie, à pelage brun noirâtre, caractérisé par un gros museau recourbé, un appendice pendant sous la gorge et de hautes épaules surmontées d&apos;une bosse</skos:definition>
        <skos:prefLabel xml:lang="fr">orginal</skos:prefLabel>
        <synonyme xml:lang="fr">élan d&apos;Amérique</synonyme>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/940b4b49_a965_426f_aac8_552142349a77 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/940b4b49_a965_426f_aac8_552142349a77">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004_9"/>
        <skos:broader rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/2fb51bce_d1bc_46c5_9a56_5145d3f9df6e"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/corde_1</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/corde</terms:source>
        <rdfs:label xml:lang="fr">corde (objet à usage polyvalent pour le traitement des matériaux)</rdfs:label>
        <skos:definition xml:lang="fr">assemblage obtenu par torsion de fils de matières textiles (chanvre, coton, laine, soie), synthétiques (nylon), métalliques ou autres (poil, crin, écorce d&apos;arbre, jonc, etc.), de grosseur et de longueur variables, et servant à lier, attacher, soutenir</skos:definition>
        <skos:prefLabel xml:lang="fr">corde</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/95c407d0_188e_436b_8070_c3678eb34ff2 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/95c407d0_188e_436b_8070_c3678eb34ff2">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0260"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/bapt%C3%AAme</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8367353/bapteme</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/bapt%C3%AAme</terms:source>
        <rdfs:label xml:lang="fr">baptême</rdfs:label>
        <skos:definition xml:lang="fr">sacrement catholique, administré au nom de la Trinité par le symbolisme de l&apos;eau, destiné à introduire une personne dans la communauté chrétienne en la purifiant du péché originel</skos:definition>
        <skos:prefLabel xml:lang="fr">baptême</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/951e98ed_d9c5_4dc7_ae1e_cf4221342b05 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/951e98ed_d9c5_4dc7_ae1e_cf4221342b05">
