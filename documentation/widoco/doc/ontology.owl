        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/4d9bd460_729d_4bc0_ba4b_050b76ac55a2"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://nomenclature.info/nom/2544</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/cape</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/2073722/cape</terms:source>
        <rdfs:comment xml:lang="fr">vêtement d&apos;extérieur ample de longueur variable, dépourvu de manches et d&apos;emmanchures, couvrant le corps et les bras, fermé au milieu du devant, sur toute sa longueur ou seulement à l’encolure, comportant parfois un capuchon, un col et des passe-bras, servant à protéger contre les intempéries et le froid</rdfs:comment>
        <rdfs:label xml:lang="fr">Cape</rdfs:label>
        <skos:prefLabel xml:lang="fr">cape</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0029 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0029">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_3"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0085"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/carte</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/3499792/carte-postale</terms:source>
        <rdfs:comment xml:lang="fr">objet de correspondance sans enveloppe, consistant en une feuille de papier fort et rigide, dont l&apos;une des faces est entièrement réservée à la correspondance, la moitié droite au moins de l&apos;autre face (recto selon la terminologie postale) étant réservée à l&apos;adresse du destinataire, à l&apos;affranchissement et aux indications postales</rdfs:comment>
        <rdfs:label xml:lang="fr">Carte postale</rdfs:label>
        <skos:prefLabel xml:lang="fr">carte postale</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0030 -->


