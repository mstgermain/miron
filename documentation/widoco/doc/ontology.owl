        <rdfs:comment xml:lang="fr">instrument en métal, creux et évasé, dont on tire des sons en frappant ses parois, à l&apos;intérieur avec un battant ou à l&apos;extérieur avec un marteau</rdfs:comment>
        <rdfs:label xml:lang="fr">Cloche</rdfs:label>
        <skos:prefLabel xml:lang="fr">cloche</skos:prefLabel>
    </owl:Class>
    


