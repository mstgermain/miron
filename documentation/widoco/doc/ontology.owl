        <rdfs:comment xml:lang="fr">meuble servant à s&apos;assoir</rdfs:comment>
        <rdfs:label xml:lang="fr">Siège</rdfs:label>
        <skos:prefLabel xml:lang="fr">siège</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0163 -->


