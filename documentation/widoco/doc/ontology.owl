        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/cuir</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/cuir</terms:source>
        <rdfs:label xml:lang="fr">cuir</rdfs:label>
        <skos:definition xml:lang="fr">matière imputrescible, relativement résistante à l&apos;eau, souple, obtenue par tannage de la peau d&apos;un animal et utilisée à diverses fins</skos:definition>
        <skos:hiddenLabel xml:lang="fr">peau, cuir</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">cuir</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/05275df3_3830_4f5c_9b21_c38af9183b73 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/05275df3_3830_4f5c_9b21_c38af9183b73">
