        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/buffet</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/buffet</terms:source>
        <rdfs:comment xml:lang="fr">meuble, parfois composé de deux corps superposés, servant à ranger la vaisselle, le linge de table, certaines provisions, etc.</rdfs:comment>
        <rdfs:label xml:lang="fr">Buffet</rdfs:label>
        <skos:prefLabel xml:lang="fr">buffet</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0034 -->


