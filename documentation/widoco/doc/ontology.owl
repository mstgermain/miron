        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8367509/relier</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/relier</terms:source>
        <rdfs:comment xml:lang="fr">action consistant à assembler et à attacher des feuillets, spécialement ceux qui composent un ouvrage, et les couvrir d&apos;une matière rigide</rdfs:comment>
        <rdfs:label xml:lang="fr">relier</rdfs:label>
        <skos:hiddenLabel xml:lang="fr">relié</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">relier</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/fbed6de7_f38f_4ea3_b7f4_66800cae9680 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/fbed6de7_f38f_4ea3_b7f4_66800cae9680">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Plante"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/%C3%A9rable</terms:source>
        <rdfs:label xml:lang="fr">érable</rdfs:label>
        <skos:definition xml:lang="fr">arbre des régions tempérées et froides de l’hémisphère Nord, souvent de grande taille, à feuilles dentées, généralement larges et profondément découpées, dont les fruits sont des samares doubles et dont plusieurs espèces sont cultivées pour leur valeur ornementale</skos:definition>
        <skos:prefLabel xml:lang="fr">érable</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/fd38382d_7787_4fb9_b48b_a1f3009de975 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/fd38382d_7787_4fb9_b48b_a1f3009de975">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/COMP001_3"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/pied</terms:source>
        <rdfs:label xml:lang="fr">pied</rdfs:label>
        <skos:definition xml:lang="fr">partie d&apos;un objet jouant un rôle de soutien</skos:definition>
        <skos:prefLabel xml:lang="fr">pied</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/0a2e01a7_4430_44f5_ac54_7f096a40e2dc -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/0a2e01a7_4430_44f5_ac54_7f096a40e2dc">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/COMP001_5"/>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/2073726/calotte</terms:source>
        <rdfs:label xml:lang="fr">calotte</rdfs:label>
        <skos:definition xml:lang="fr">partie principale du chapeau qui couvre plus ou moins la tête</skos:definition>
        <skos:prefLabel xml:lang="fr">calotte</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/0b6b53d7_b40f_4c9b_ac6e_50f6e1e1b256 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/0b6b53d7_b40f_4c9b_ac6e_50f6e1e1b256">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0260"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/p%C3%A9nitence</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/r%C3%A9conciliation#aa9E5Dfd23453e59</terms:source>
        <rdfs:label xml:lang="fr">réconciliation ou pénitence</rdfs:label>
        <skos:definition xml:lang="fr">sacrement catholique par lequel le prêtre donne l’absolution au confessé et par lequel un pécheur se réconcilie avec Dieu, avec l&apos;Église</skos:definition>
        <skos:prefLabel xml:lang="fr">réconciliation ou pénitence</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/0c649efc_ec12_48d7_badb_4f05ca05cc83 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/0c649efc_ec12_48d7_badb_4f05ca05cc83">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Plante"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/cotonnier</terms:source>
        <rdfs:label xml:lang="fr">cotonnier</rdfs:label>
        <skos:definition xml:lang="fr">plante originaire des régions tropicales et subtropicales, voisine de l’hibiscus, dont on cultive certaines espèces pour leurs fruits à graines oléagineuses qui fournissent la fibre de coton, destinée à la fabrication textile, et une huile végétale, utilisée à des fins alimentaires, cosmétiques ou industrielles</skos:definition>
        <skos:prefLabel xml:lang="fr">cotonnier</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/0e52806e_fce8_493e_b395_1b0ed26c8e5d -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/0e52806e_fce8_493e_b395_1b0ed26c8e5d">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/COMP001_3"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/anse</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/anse</terms:source>
        <rdfs:label xml:lang="fr">anse</rdfs:label>
        <skos:definition xml:lang="fr">partie saillante en forme d’arc ou d’anneau, servant à saisir et porter un objet</skos:definition>
        <skos:prefLabel xml:lang="fr">anse</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/02ee4f75_f7a9_4182_b176_9e7f046ffb59 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/02ee4f75_f7a9_4182_b176_9e7f046ffb59">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/COMP001_3"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/tige</terms:source>
        <rdfs:label xml:lang="fr">tige (composant d’objet à usage polyvalent)</rdfs:label>
        <skos:definition xml:lang="fr">partie d&apos;un objet allongée, cylindrique et généralement rigide</skos:definition>
        <skos:prefLabel xml:lang="fr">tige</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/02712e9b_d956_4a33_9cdb_ac6cf91e3cab -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/02712e9b_d956_4a33_9cdb_ac6cf91e3cab">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0231"/>
