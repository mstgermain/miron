                                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/c7a2524b_6bd3_4239_8e4d_7609c30ae592"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/accessoireObjet"/>
                        <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_421"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                        <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/1f69d6da_0473_414d_a575_244bf1de5f44"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_41"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/archet</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/2199891/archet</terms:source>
        <rdfs:comment xml:lang="fr">baguette de bois, généralement de bois de Pernambouc, flexible, droite ou légèrement incurvée, munie d&apos;un faisceau de crins de cheval fixé à ses deux extrémités, servant, lorsque frottée sur les cordes de certains instruments de musique, à les faire vibrer et à commander la durée et l&apos;intensité du son</rdfs:comment>
        <rdfs:label xml:lang="fr">Archet</rdfs:label>
        <skos:prefLabel xml:lang="fr">archet</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0221 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0221">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_7"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:qualifiedCardinality>
                        <owl:onClass>
                            <owl:Class>
                                <owl:oneOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/168d926f_0bb8_4f12_9b38_94bfa0bc4a25"/>
                                </owl:oneOf>
                            </owl:Class>
                        </owl:onClass>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_7"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/tire-ligne</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/tire-ligne</terms:source>
        <rdfs:comment xml:lang="fr">instrument emmanché à deux lamelles plates, à écartement réglable, terminées en pointe, servant à tracer des lignes d&apos;épaisseur constante</rdfs:comment>
        <rdfs:label xml:lang="fr">Tire-ligne</rdfs:label>
        <skos:prefLabel xml:lang="fr">tire-ligne</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0222 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0222">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0082"/>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                                <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0082"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                                <owl:onClass rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0082"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/alliage</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8395342/alliage</terms:source>
        <rdfs:comment xml:lang="fr">corps métallique issu du mélange d&apos;un métal avec un ou plusieurs éléments, métalliques ou non, miscibles les uns aux autres lorsqu&apos;ils sont fondus et qui ne se séparent pas en couches distinctes lorsqu&apos;ils sont solides, afin d&apos;obtenir des propriétés mécaniques précises</rdfs:comment>
        <rdfs:comment>http://vocab.getty.edu/page/aat/300010902</rdfs:comment>
        <rdfs:label xml:lang="fr">Alliage</rdfs:label>
        <skos:prefLabel xml:lang="fr">alliage</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0223 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0223">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0271"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/boisson</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8872875/boisson</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/boisson</terms:source>
        <rdfs:comment xml:lang="fr">tout liquide qui se boit</rdfs:comment>
        <rdfs:label xml:lang="fr">Boisson</rdfs:label>
        <skos:prefLabel xml:lang="fr">boisson</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0226 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0226">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E55_Type"/>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8364368/organisme</terms:source>
        <rdfs:comment xml:lang="fr">système formant une unité distincte et autonome constituée d&apos;une ou de plusieurs cellules, ayant la capacité de se développer et assurant son existence par un échange avec son environnement</rdfs:comment>
        <rdfs:label xml:lang="fr">Organisme vivant</rdfs:label>
        <skos:prefLabel xml:lang="fr">organisme vivant</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0227 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0227">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E55_Type"/>
        <terms:source>http://vocab.getty.edu/page/aat/300053001</terms:source>
        <rdfs:comment xml:lang="fr">action permettant de réaliser une activité particulière ou d&apos;obtenir un résultat prédéterminé, exécutée sur ou avec des matériaux ou des objets</rdfs:comment>
        <rdfs:label xml:lang="fr">Procédé ou technique</rdfs:label>
        <skos:prefLabel xml:lang="fr">procédé ou technique</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0228 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0228">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0197"/>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0275"/>
        <terms:source>http://vocab.getty.edu/page/aat/300386673</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8396691/fibre-animale</terms:source>
        <rdfs:comment xml:lang="fr">fibre d&apos;origine animale</rdfs:comment>
        <rdfs:label xml:lang="fr">Fibre animale</rdfs:label>
        <skos:prefLabel xml:lang="fr">fibre animale</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0229 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0229">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0197"/>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0235"/>
        <terms:source>http://vocab.getty.edu/page/aat/300014031</terms:source>
        <rdfs:comment xml:lang="fr">fibre d&apos;origine végétale, y compris l&apos;écorce, les tiges, les feuilles ou les graines</rdfs:comment>
        <rdfs:label xml:lang="fr">Fibre végétale</rdfs:label>
        <skos:prefLabel xml:lang="fr">fibre végétale</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0231 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0231">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0275"/>
        <terms:source xml:lang="fr">http://vocab.getty.edu/page/aat/300193287</terms:source>
        <rdfs:comment xml:lang="fr">matière animale ayant été conservée ou ayant subi un traitement particulier</rdfs:comment>
        <rdfs:label xml:lang="fr">Matière animale transformée</rdfs:label>
        <skos:prefLabel xml:lang="fr">matière animale transformée</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0232 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0232">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <terms:source>http://vocab.getty.edu/page/aat/300015121</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/explosif</terms:source>
        <rdfs:comment xml:lang="fr">matériau, généralement un composé ou mélange de corps, susceptible d’exploser et produit dans le but de provoquer une explosion</rdfs:comment>
        <rdfs:label xml:lang="fr">Matière explosive</rdfs:label>
        <skos:prefLabel xml:lang="fr">matière explosive</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0233 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0233">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8483887/matiere-inorganique</terms:source>
        <rdfs:comment xml:lang="fr">substance qui n&apos;a pas de structure moléculaire à base de carbone</rdfs:comment>
        <rdfs:label xml:lang="fr">Matière inorganique</rdfs:label>
        <skos:prefLabel xml:lang="fr">matière inorganique</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0234 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0234">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                        <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/f4e40103_2809_47fa_974c_3aaa1ceffba2"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <terms:source>http://vocab.getty.edu/page/aat/300011792</terms:source>
        <rdfs:comment xml:lang="fr">matériau contenant du carbone, y compris ceux issus d&apos;organismes vivants</rdfs:comment>
        <rdfs:label xml:lang="fr">Matière organique</rdfs:label>
        <skos:prefLabel xml:lang="fr">matière organique</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0235 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0235">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0234"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/materiauOrganismeVivant"/>
                        <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Plante"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0234"/>
        <rdfs:comment xml:lang="fr">matière organique d&apos;origine végétale</rdfs:comment>
        <rdfs:label xml:lang="fr">Matière végétale</rdfs:label>
        <skos:prefLabel xml:lang="fr">matière végétale</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0236 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0236">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0233"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/min%C3%A9ral</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8879127/mineral</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/min%C3%A9ral</terms:source>
        <rdfs:comment xml:lang="fr">matière inorganique naturelle homogène, généralement solide, caractérisée par une composition chimique déterminée et une structure ordonnée, composant l&apos;écorce terrestre, et plus spécialement qui constitue les matériaux de la surface du globe</rdfs:comment>
        <rdfs:label xml:lang="fr">Minéral</rdfs:label>
        <skos:prefLabel xml:lang="fr">minéral</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0253 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0253">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_3"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/resultatProcedeOuTechnique"/>
                        <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/5e9d8429_73d6_4b44_a1a3_93c5a06af14d"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_3"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/cahier</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/2069254/cahier</terms:source>
        <rdfs:comment xml:lang="fr">assemblage de feuilles de papier, agrafées ou cousues, protégées par une couverture et destinées à recevoir des notes manuscrites, des dessins, etc.</rdfs:comment>
        <rdfs:label xml:lang="fr">Cahier</rdfs:label>
        <skos:prefLabel xml:lang="fr">cahier</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0254 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0254">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0275"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/materiauOrganismeVivant"/>
                <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Mammifere"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>http://vocab.getty.edu/page/aat/300011826</terms:source>
        <terms:source>https://terminology.collectionstrust.org.uk/British-Museum-materials/mathesh.htm#933</terms:source>
        <rdfs:comment xml:lang="fr">matière animale composant les structures protéiques dures et semi-translucides poussant sur la tête de certains mammifères</rdfs:comment>
        <rdfs:label xml:lang="fr">Corne</rdfs:label>
        <skos:prefLabel xml:lang="fr">corne</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0255 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0255">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0082"/>
        <terms:source>http://vocab.getty.edu/page/aat/300011054</terms:source>
        <rdfs:comment xml:lang="fr">métal considéré comme ayant une valeur intrinsèque élevée</rdfs:comment>
        <rdfs:label xml:lang="fr">Métal précieux</rdfs:label>
        <skos:prefLabel xml:lang="fr">métal précieux</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0256 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0256">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0234"/>
        <terms:source>http://vocab.getty.edu/page/aat/300014570</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8402245/plastique</terms:source>
        <rdfs:comment xml:lang="fr">matière organique naturelle ou synthétique constituée de macromolécules obtenues par polymérisation ou polycondensation et possédant, en général, la propriété d&apos;être coulée, extrudée, modelée ou moulée lorsqu&apos;elle est malléable ou liquide, puis rendue rigide ou légèrement élastique</rdfs:comment>
        <rdfs:label xml:lang="fr">Plastique</rdfs:label>
        <skos:prefLabel xml:lang="fr">plastique</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0257 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0257">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0272"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                        <owl:someValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0197"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0272"/>
        <rdfs:comment xml:lang="fr">matériau produit à partir de fibres animales, synthétiques ou végétales</rdfs:comment>
        <rdfs:label xml:lang="fr">Produit des fibres</rdfs:label>
        <skos:prefLabel xml:lang="fr">produit des fibres</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0258 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0258">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0235"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/r%C3%A9sine</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/26531295/resine</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/r%C3%A9sine</terms:source>
        <rdfs:comment xml:lang="fr">matière végétale sécrétée par plusieurs plantes ligneuses, notamment des Conifères, qui contient des dérivés de phénols et de terpènes, solide ou semi-fluide, à cassure vitreuse, inflammable, non soluble dans l&apos;eau, de couleur jaune ou brune</rdfs:comment>
        <rdfs:label xml:lang="fr">Résine</rdfs:label>
        <skos:prefLabel xml:lang="fr">résine</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0259 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0259">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E55_Type"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/rite</terms:source>
        <rdfs:comment xml:lang="fr">ensemble de prescriptions qui règlent la célébration du culte en usage dans une communauté religieuse</rdfs:comment>
        <rdfs:label xml:lang="fr">Rite religieux</rdfs:label>
        <skos:prefLabel xml:lang="fr">rite religieux</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0260 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0260">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0259"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/sacrement</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8364338/sacrement</terms:source>
        <rdfs:comment xml:lang="fr">acte rituel, signe sacré de la grâce, institué par Jésus-Christ et actualisé dans l&apos;Église, source par lui-même de la grâce divine à faire naître ou à augmenter</rdfs:comment>
        <rdfs:label xml:lang="fr">Sacrement catholique</rdfs:label>
        <skos:prefLabel xml:lang="fr">sacrement catholique</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0270 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0270">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT007_21"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/accessoireObjet"/>
                <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT007_22"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0083"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/aviron</terms:source>
        <rdfs:comment xml:lang="fr">instrument formé d&apos;un manche de bois dont l&apos;extrémité large et plate sert à propulser et à manœuvrer une embarcation</rdfs:comment>
        <rdfs:label xml:lang="fr">Aviron</rdfs:label>
        <skos:prefLabel xml:lang="fr">aviron</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0271 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0271">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/17075446/aliment</terms:source>
        <rdfs:comment xml:lang="fr">substance dont l&apos;introduction dans l&apos;organisme contribue, après digestion, au maintien, à la croissance et au renouvellement des tissus, ainsi qu&apos;à la satisfaction des besoins énergétiques</rdfs:comment>
        <rdfs:label xml:lang="fr">Aliment</rdfs:label>
        <skos:prefLabel xml:lang="fr">aliment</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0272 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0272">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <rdfs:comment xml:lang="fr">substance, naturelle ou synthétique, longue, mince, flexible, ou matériau produit à partir de ces éléments</rdfs:comment>
        <rdfs:label xml:lang="fr">Fibre ou produit des fibres</rdfs:label>
        <skos:prefLabel xml:lang="fr">fibre ou produit des fibres</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0273 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0273">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0121"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/toile</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/17558681/toile</terms:source>
        <rdfs:comment xml:lang="fr">tissu d’armure unie ou simple, quelle que soit la matière avec laquelle il est exécuté</rdfs:comment>
        <rdfs:label xml:lang="fr">Toile</rdfs:label>
        <skos:prefLabel xml:lang="fr">toile</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0274 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0274">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0236"/>
        <terms:source>https://terminology.collectionstrust.org.uk/British-Museum-materials/mathesc.htm#475</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/argile</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8400740/argile</terms:source>
        <rdfs:comment xml:lang="fr">matière minérale terreuse à structure bi-dimensionnelle (feuillets) constituée principalement de silicates d&apos;aluminium hydratés en fines particules, d&apos;un diamètre inférieur à 2 microns, ayant généralement l&apos;aspect d&apos;une terre molle, imperméable</rdfs:comment>
        <rdfs:label xml:lang="fr">Argile</rdfs:label>
        <skos:prefLabel xml:lang="fr">argile</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0275 -->


