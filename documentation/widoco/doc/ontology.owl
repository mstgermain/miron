        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                <owl:someValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0229"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://terminology.collectionstrust.org.uk/British-Museum-materials/mathesp.htm#1431</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/papier</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/2093118/papier</terms:source>
        <rdfs:comment xml:lang="fr">produit de fibres végétales naturelles ou transformées, réduites en une pâte homogène que l&apos;on étend et sèche pour former une feuille mince</rdfs:comment>
        <rdfs:label xml:lang="fr">Papier</rdfs:label>
        <skos:prefLabel xml:lang="fr">papier</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0092 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0092">
