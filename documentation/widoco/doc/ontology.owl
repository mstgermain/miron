        <terms:source>https://www.cnrtl.fr/definition/br%C3%BBle-parfum</terms:source>
        <rdfs:comment xml:lang="fr">petit récipient servant à brûler des substances aromatiques</rdfs:comment>
        <rdfs:label xml:lang="fr">Brûle-parfum</rdfs:label>
        <skos:prefLabel xml:lang="fr">brûle-parfum</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0182 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0182">
