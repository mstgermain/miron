        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/17028601/verre</terms:source>
        <rdfs:comment xml:lang="fr">matière inorganique solide, amorphe, formée de silicate alcalin, dure, fragile, généralement transparente, mais peut aussi être translucide ou opaque</rdfs:comment>
        <rdfs:label xml:lang="fr">Verre</rdfs:label>
        <skos:prefLabel xml:lang="fr">verre</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0129 -->


