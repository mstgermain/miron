    <!-- https://stgermain.ebsi.umontreal.ca/miron/970d84c4_2b52_4962_b5b7_1ee18fdd5529 -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/970d84c4_2b52_4962_b5b7_1ee18fdd5529">
