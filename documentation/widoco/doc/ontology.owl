            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8879931/embarcation</terms:source>
        <rdfs:comment xml:lang="fr">moyen de transport sur l&apos;eau, de petite dimension</rdfs:comment>
        <rdfs:label xml:lang="fr">Embarcation</rdfs:label>
        <skos:prefLabel xml:lang="fr">embarcation</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT007_3 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT007_3">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT007"/>
        <terms:source>https://nomenclature.info/nom/11800</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la manutention ou le transport créé pour transporter des personnes ou des biens par voie terrestre sans restriction à un itinéraire fixe déterminé par un appareil de localisation ou autre dispositif de guidage</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le transport terrestre</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, transport terrestre</skos:altLabel>
        <skos:prefLabel xml:lang="fr">objet pour le transport terrestre</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT007_31 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT007_31">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT007_3"/>
        <terms:source>https://nomenclature.info/nom/12122</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat7_9</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le transport terrestre mû uniquement par l&apos;énergie humaine</rdfs:comment>
        <rdfs:label xml:lang="fr">Véhicule à propulsion ou à traction humaine</rdfs:label>
        <skos:altLabel xml:lang="fr">transport terrestre à traction ou à propulsion humaine</skos:altLabel>
        <skos:altLabel xml:lang="fr">véhicules à traction ou à propulsion humaine</skos:altLabel>
        <skos:example xml:lang="fr">brancard;bicyclette;raquette</skos:example>
        <skos:prefLabel xml:lang="fr">véhicule à propulsion ou à traction humaine</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT008 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT008">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <terms:source>https://nomenclature.info/nom/12838</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#Categorie8</terms:source>
        <rdfs:comment xml:lang="fr">objet élaboré par l&apos;humain créé en tant qu&apos;expression de la pensée humaine</rdfs:comment>
        <rdfs:label xml:lang="fr">Moyen d’expression</rdfs:label>
        <skos:altLabel xml:lang="fr">moyens d&apos;expression</skos:altLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 08</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 8</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">moyen d&apos;expression</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Les moyens d&apos;expression commentent, interprètent ou améliorent l&apos;environnement des personnes, et peuvent fonctionner symboliquement ou littéralement.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT008_1 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT008_1">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008"/>
        <terms:source>https://nomenclature.info/nom/13807</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat8_3</terms:source>
        <rdfs:comment xml:lang="fr">moyen d&apos;expression créé pour être utilisé en tant qu&apos;instrument d&apos;échange ou en tant que moyen d&apos;obtenir des biens et services particuliers</rdfs:comment>
        <rdfs:label xml:lang="fr">Instrument d’échange</rdfs:label>
        <skos:altLabel xml:lang="fr">monnaie d&apos;échange</skos:altLabel>
        <skos:altLabel xml:lang="fr">monnaies d&apos;échange</skos:altLabel>
        <skos:editorialNote xml:lang="fr">Le terme « instrument d&apos;échange » a été privilégié pour désigner cette classe plutôt que « monnaie d&apos;échange » utilisé dans le Système de classification en ethnologie, histoire et archéologie du guide de documentation du Réseau Info-Muse (SMQ) et dans la norme Nomenclature pour le catalogage des objets de musée (RCIP). Le terme « instrument d&apos;échange » désigne « tout ce qui est généralement accepté à titre de paiement, quel que soit le support ou le procédé technique utilisé, pour l&apos;acquisition de biens ou de services ou pour le règlement d&apos;une créance ou de tout autre engagement » (https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/503549/instrument-dechange). La monnaie constitue un type d&apos;instrument d&apos;échange. Ce terme correspond donc mieux à la portée de la définition de la classe, et donc, du concept.</skos:editorialNote>
        <skos:example xml:lang="fr">pièce de monnaie;billet de banque;coquillage;timbre-poste;billet d&apos;entrée;coupon de réduction;jeton;billet de métro</skos:example>
        <skos:prefLabel xml:lang="fr">instrument d’échange</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT008_2 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT008_2">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008"/>
        <terms:source>https://nomenclature.info/nom/13265</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat8_7</terms:source>
        <rdfs:comment xml:lang="fr">moyen d&apos;expression créé pour communiquer des informations à des personnes</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet documentaire</rdfs:label>
        <skos:altLabel xml:lang="fr">objets documentaires</skos:altLabel>
        <skos:altLabel xml:lang="fr">pièces et documents</skos:altLabel>
        <skos:prefLabel xml:lang="fr">objet documentaire</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Les objets documentaires présentent un point de vue, une image ou un ensemble d&apos;idées, souvent dans le but d&apos;éclairer ou d&apos;influencer l&apos;attitude des personnes.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT008_21 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT008_21">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT008_2"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/souvenirEntite"/>
                        <owl:someValuesFrom rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008_2"/>
        <terms:source>https://nomenclature.info/nom/13568</terms:source>
        <rdfs:comment xml:lang="fr">objet documentaire symbolique en souvenir ou commémorant une personne, un lieu, un événement ou une expérience</rdfs:comment>
        <rdfs:label xml:lang="fr">Souvenir</rdfs:label>
        <skos:altLabel xml:lang="fr">Souvenirs</skos:altLabel>
        <skos:prefLabel xml:lang="fr">souvenir</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT008_3 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT008_3">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008"/>
        <terms:source>https://nomenclature.info/nom/12986</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat8_4</terms:source>
        <rdfs:comment xml:lang="fr">moyen d&apos;expression créé pour des activités gouvernementales, fraternelles, religieuses ou pour d&apos;autres activités sociales organisées et sanctionnées, ou pour évoquer, symboliser ou exprimer certains aspects des traditions ou du patrimoine d&apos;une communauté ou d&apos;un groupe de personnes</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la cérémonie et le culte</rdfs:label>
        <skos:altLabel xml:lang="fr">Objet de cérémonie et de culte</skos:altLabel>
        <skos:altLabel xml:lang="fr">Objets cérémoniels</skos:altLabel>
        <skos:example xml:lang="fr">coupe de communion;décoration d&apos;autel;fanion</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour la cérémonie et le culte</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Les objets pour la cérémonie et le culte sont habituellement associés à des rituels ou à des cérémonies.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT008_31 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT008_31">
