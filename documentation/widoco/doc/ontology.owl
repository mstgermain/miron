        <rdfs:comment xml:lang="fr">fibre tissée, tricotée, en feutre, aiguilletée ou réalisée selon tout autre mode de production</rdfs:comment>
        <rdfs:label xml:lang="fr">Étoffe</rdfs:label>
        <skos:prefLabel xml:lang="fr">étoffe</skos:prefLabel>
    </owl:Class>
    


