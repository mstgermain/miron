        <rdfs:comment xml:lang="fr">véhicule ferroviaire, soit à force motrice et à moteur, soit à moteur seul (locomotive électrique), servant à déplacer et à acheminer d&apos;autres véhicules</rdfs:comment>
        <rdfs:label xml:lang="fr">Locomotive</rdfs:label>
        <skos:prefLabel xml:lang="fr">locomotive</skos:prefLabel>
    </owl:Class>
    


