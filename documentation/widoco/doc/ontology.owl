        <rdfs:label xml:lang="fr">manche (composant d’objet à usage polyvalent)</rdfs:label>
        <skos:definition xml:lang="fr">partie d&apos;un outil, d&apos;un instrument, généralement de forme allongée et plus ou moins droite, par laquelle on le tient lorsqu&apos;on l&apos;utilise</skos:definition>
        <skos:prefLabel xml:lang="fr">manche</skos:prefLabel>
    </owl:NamedIndividual>
    


