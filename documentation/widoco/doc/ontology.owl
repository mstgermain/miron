        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8349995/album</terms:source>
        <rdfs:comment xml:lang="fr">cahier, relié ou à feuillets, servant à contenir des notes, des dessins ou des objets de collection divers</rdfs:comment>
        <rdfs:label xml:lang="fr">Album</rdfs:label>
        <skos:prefLabel xml:lang="fr">album</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0093 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0093">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008_2"/>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008_6"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/resultatProcedeOuTechnique"/>
                <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Photographie"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/photographie</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/17075837/photographie</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/photographie</terms:source>
        <rdfs:comment xml:lang="fr">objet documentaire ou œuvre visuelle consistant en une image durable obtenue par des procédés photographiques</rdfs:comment>
        <rdfs:label xml:lang="fr">Photographie</rdfs:label>
        <skos:editorialNote xml:lang="fr">Le terme « photographie » est généralement utilisé pour désigner l&apos;image positive.</skos:editorialNote>
        <skos:example xml:lang="fr">hologramme;photographie numérique</skos:example>
        <skos:prefLabel xml:lang="fr">photographie</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0094 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0094">
