        <terms:source>https://www.cnrtl.fr/definition/fourrure</terms:source>
        <rdfs:comment xml:lang="fr">peau qui, après avoir subi un traitement approprié, sert à confectionner ou à garnir des vêtements, des parures, des articles d&apos;ameublement, etc.</rdfs:comment>
        <rdfs:label xml:lang="fr">Fourrure</rdfs:label>
        <skos:prefLabel xml:lang="fr">fourrure</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0126 -->


