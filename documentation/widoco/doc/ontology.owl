        <rdfs:label xml:lang="fr">Casse-tête (arme contondante)</rdfs:label>
        <skos:prefLabel xml:lang="fr">casse-tête</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0032 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0032">
