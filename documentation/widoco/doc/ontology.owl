        <rdfs:label xml:lang="fr">coton (fibre)</rdfs:label>
        <skos:definition xml:lang="fr">fibre végétale soyeuse blanche à jaunâtre, entourant les graines du cotonnier</skos:definition>
        <skos:hiddenLabel xml:lang="fr">fibre, coton</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">coton</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/fb3b9439_5f10_4310_a165_15d5dfb6858f -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/fb3b9439_5f10_4310_a165_15d5dfb6858f">
        <rdf:type rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/AdditionAssemblage"/>
