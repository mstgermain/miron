        <rdfs:label xml:lang="fr">Chaise</rdfs:label>
        <skos:prefLabel xml:lang="fr">chaise</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR076 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR076">
