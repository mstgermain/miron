                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/952bf3c3_3caa_43c0_a72d_a2df4b39de0f"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/violon</terms:source>
        <rdfs:comment xml:lang="fr">instrument à cordes frottées avec un archet, dont on joue en le tenant entre l&apos;épaule et le menton, et dont le manche, recouvert d&apos;une touche, se termine par une volute</rdfs:comment>
        <rdfs:label xml:lang="fr">Violon</rdfs:label>
        <skos:prefLabel xml:lang="fr">violon</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0076 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0076">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_2"/>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT009_2"/>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/18592798/zootrope</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/zootrope</terms:source>
        <rdfs:comment xml:lang="fr">jouet dans lequel les mouvements décomposés d&apos;un être vivant sont observés à travers les fentes d&apos;un cylindre tournant, de manière à créer l&apos;illusion du mouvement</rdfs:comment>
        <rdfs:label xml:lang="fr">Zootrope</rdfs:label>
        <skos:altLabel xml:lang="fr">zoétrope cylindrique</skos:altLabel>
        <skos:prefLabel xml:lang="fr">zootrope</skos:prefLabel>
    </owl:Class>
    


