        <rdfs:label xml:lang="fr">jute (fibre)</rdfs:label>
        <skos:definition xml:lang="fr">fibre végétale libérienne très résistante issue de la plante de jute</skos:definition>
        <skos:hiddenLabel xml:lang="fr">fibre, jute</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">jute</skos:prefLabel>
