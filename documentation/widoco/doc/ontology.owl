        <terms:source>https://www.cnrtl.fr/definition/bretelle</terms:source>
        <rdfs:label xml:lang="fr">bretelle</rdfs:label>
        <skos:definition xml:lang="fr">bande de cuir, d&apos;étoffe, qui, fixée à un objet lourd ou encombrant et passée sur l&apos;épaule, permet de le porter plus facilement</skos:definition>
        <skos:prefLabel xml:lang="fr">bretelle</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/952bf3c3_3caa_43c0_a72d_a2df4b39de0f -->


    <owl:NamedIndividual rdf:about="https://stgermain.ebsi.umontreal.ca/miron/952bf3c3_3caa_43c0_a72d_a2df4b39de0f">
