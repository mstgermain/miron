    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P198_holds_or_supports"/>
    


    <!-- http://www.cidoc-crm.org/cidoc-crm/P46_is_composed_of -->


    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P46_is_composed_of">
        <owl:equivalentProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
