        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/bois</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/bois</terms:source>
        <rdfs:comment xml:lang="fr">matière végétale compacte et fibreuse qui constitue l’arbre ou une partie de celui-ci utilisée dans la fabrication de nombreux objets</rdfs:comment>
        <rdfs:label xml:lang="fr">Bois</rdfs:label>
        <skos:prefLabel xml:lang="fr">bois</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0085 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0085">
