        <rdfs:comment xml:lang="fr">thème ornemental ou figuratif, habituellement répété</rdfs:comment>
        <rdfs:label xml:lang="fr">Motif</rdfs:label>
        <skos:prefLabel xml:lang="fr">motif</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0178 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0178">
