        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/herbe</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/herbe</terms:source>
        <rdfs:comment xml:lang="fr">matière végétale comprenant les tiges ou les feuilles d&apos;une plante phanérogame non ligneuse, annuelle, bisannuelle ou vivace, à tige molle et généralement verte, et dont les parties aériennes meurent chaque année</rdfs:comment>
        <rdfs:label xml:lang="fr">Herbe</rdfs:label>
        <skos:prefLabel xml:lang="fr">herbe</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0186 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0186">
