        <rdfs:label xml:lang="fr">Procédé ou technique de création d’images</rdfs:label>
        <skos:prefLabel xml:lang="fr">procédé ou technique de création d’images</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/Impression -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/Impression">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CreationImages"/>
        <terms:source>http://vocab.getty.edu/page/aat/300053319</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/impression</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/impression</terms:source>
        <rdfs:comment xml:lang="fr">procédé ou technique de reproduction par pression ou contact d&apos;une surface, généralement une plaque, un bloc, une pierre ou un écran, portant des traces enduites d&apos;encre correspondant à une image picturale ou textuelle sur une autre, généralement en papier ou en tissu, qui en reçoit l&apos;empreinte</rdfs:comment>
        <rdfs:label xml:lang="fr">Procédé ou technique d’impression</rdfs:label>
        <skos:prefLabel xml:lang="fr">procédé ou technique d’impression</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/Insecte -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/Insecte">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/Animal"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/insecte</terms:source>
        <rdfs:comment xml:lang="fr">petit animal invertébré de type arthropode, pourvu de deux antennes, de trois paires de pattes et, chez la plupart des espèces, d’une ou de deux paires d’ailes, dont le corps présente trois parties principales bien distinctes (la tête, le thorax et l’abdomen) et dont le développement complet comporte généralement différents stades (larve, nymphe, adulte) et d’importantes métamorphoses</rdfs:comment>
        <rdfs:label xml:lang="fr">Insecte</rdfs:label>
        <skos:prefLabel xml:lang="fr">insecte</skos:prefLabel>
    </owl:Class>
    


