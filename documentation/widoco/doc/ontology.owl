        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8398232/fibre</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/textile</terms:source>
        <rdfs:comment xml:lang="fr">élément de matière, naturel ou synthétique, long, mince, flexible</rdfs:comment>
        <rdfs:label xml:lang="fr">Fibre</rdfs:label>
        <skos:prefLabel xml:lang="fr">fibre</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0201 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0201">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0233"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                <owl:someValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0236"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>http://vocab.getty.edu/page/aat/300235507</terms:source>
        <terms:source>https://terminology.collectionstrust.org.uk/British-Museum-materials/mathesc.htm#420</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/2199784/ceramique</terms:source>
        <rdfs:comment xml:lang="fr">matériau solide, cassant, résistant à la chaleur et à la corrosion, à base de matières minérales, dont l&apos;argile, cuites à haute température</rdfs:comment>
        <rdfs:label xml:lang="fr">Céramique</rdfs:label>
        <skos:prefLabel xml:lang="fr">céramique</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0203 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0203">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT003_1"/>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8361465/cosmetique</terms:source>
        <rdfs:comment xml:lang="fr">substance ou préparation destinée à être appliquée sur la peau, les cheveux, les dents ou les muqueuses buccales en vue de les nettoyer, de les protéger, de les maintenir en bon état, d&apos;en modifier l&apos;aspect, de les parfumer ou d&apos;en corriger l&apos;odeur</rdfs:comment>
        <rdfs:label xml:lang="fr">Cosmétique</rdfs:label>
        <skos:prefLabel xml:lang="fr">cosmétique</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0204 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0204">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0178"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/952bf3c3_3caa_43c0_a72d_a2df4b39de0f"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/17031046/scie-alternative</terms:source>
        <rdfs:comment xml:lang="fr">scie munie d&apos;une lame de coupe dentée sur une rive, disposée dans le prolongement du manche, effectuant un mouvement rectiligne alternatif à l&apos;horizontale ou à la verticale, servant principalement aux coupes de dégrossissage et aux travaux de démolition</rdfs:comment>
        <rdfs:label xml:lang="fr">Scie alternative</rdfs:label>
        <skos:prefLabel xml:lang="fr">scie alternative</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0206 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0206">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0129"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                        <owl:someValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0136"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0129"/>
        <rdfs:comment xml:lang="fr">étoffe fabriquée à partir de la fibre de la toison du mouton et d&apos;autres mammifères</rdfs:comment>
        <rdfs:label xml:lang="fr">Laine (étoffe)</rdfs:label>
        <skos:prefLabel xml:lang="fr">laine</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0207 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0207">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0121"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                        <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0133"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0121"/>
        <rdfs:comment xml:lang="fr">tissu obtenu à partir de la soie</rdfs:comment>
        <rdfs:label xml:lang="fr">Soie (tissu)</rdfs:label>
        <skos:prefLabel xml:lang="fr">soie</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0216 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0216">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_41"/>
                    <owl:Class>
