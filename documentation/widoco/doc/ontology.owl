    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/Finition">
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/finition</terms:source>
        <rdfs:comment xml:lang="fr">Cette classe comprend les actions permettant de parfaire une exécution ou une fabrication.</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/FinitionMetal">
        <rdfs:comment xml:lang="fr">Cette classe comprend les actions permettant d&apos;appliquer une finition sur une pièce de métal.</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/joint">
        <rdfs:comment xml:lang="fr">Cette propriété décrit la relation unissant une instance de la classe « Technique ou procédé pour assembler » et au moins deux objets joints par le biais de cette instance.</rdfs:comment>
        <rdfs:label xml:lang="fr">joint</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/miron/materiau/1ae9b62f_568a_46f9_8a7c_0a025abc9802">
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8362664/acier-inoxydable</terms:source>
        <skos:altLabel xml:lang="fr">acier inox</skos:altLabel>
        <skos:altLabel xml:lang="fr">inox</skos:altLabel>
        <skos:definition xml:lang="fr">acier allié au chrome et au nickel, pratiquement inaltérable à l&apos;air, résistant à divers agents de corrosion en milieu sec ou humide, à une température élevée ou cryogénique</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/miron/materiau/14561c34_6364_4e00_b16e_7d3e617d527f">
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8363170/acier-galvanise</terms:source>
        <skos:definition xml:lang="fr">acier qui a été recouvert d&apos;une couche de zinc afin de former à sa surface un revêtement anticorrosion</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/miron/objet/6032d27e_ff0b_4c68_859d_38eaf6d0fa17">
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/aiguille</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/aiguille</terms:source>
        <skos:altLabel xml:lang="fr">aiguille à chas</skos:altLabel>
        <skos:definition xml:lang="fr">tige, généralement métallique, dont l&apos;une des extrémités est effilée, l&apos;autre percée d&apos;un trou (le chas) permettant de passer un fil, utilisée dans les travaux de couture, de broderie, de tapisserie, etc.</skos:definition>
    </rdf:Description>
