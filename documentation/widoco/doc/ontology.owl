        <terms:source>https://www.cnrtl.fr/definition/tramway</terms:source>
        <rdfs:comment xml:lang="fr">véhicule ferroviaire circulant sur un chemin de fer électrique à rails plats, principalement en surface, installé en site propre ou intégré au réseau routier, servant au transport en commun dans une ville et ses banlieues</rdfs:comment>
        <rdfs:label xml:lang="fr">Tramway</rdfs:label>
        <skos:prefLabel xml:lang="fr">tramway</skos:prefLabel>
    </owl:Class>
    


