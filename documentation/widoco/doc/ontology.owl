                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/987432c2_788f_4a93_b307_86d82a74b10e"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/canne_1</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8892962/canne</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/canne</terms:source>
        <rdfs:comment xml:lang="fr">bâton en bois ou en métal à l’extrémité le plus souvent recourbée ou muni d&apos;une poignée, servant d&apos;appui à une personne qui marche</rdfs:comment>
        <rdfs:label xml:lang="fr">Canne</rdfs:label>
        <skos:prefLabel xml:lang="fr">canne</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0027 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0027">
