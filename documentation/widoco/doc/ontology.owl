        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008_31"/>
        <terms:source>http://data.culture.fr/thesaurus/resource/ark:/67717/T69-702</terms:source>
        <rdfs:comment xml:lang="fr">objet du culte catholique pouvant contenir l&apos;eau nécessaire aux ablutions ou à l&apos;aspersion et l&apos;encens nécessaire à l&apos;encensement</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour l’ablution, l’aspersion ou l’encensement</rdfs:label>
        <skos:prefLabel xml:lang="fr">objet pour l’ablution, l’aspersion ou l’encensement</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT008_4 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT008_4">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008"/>
        <terms:source>https://nomenclature.info/nom/12839</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat8_9</terms:source>
        <rdfs:comment xml:lang="fr">moyen d&apos;expression créé pour attirer l&apos;attention du public sur un produit, un service ou un événement et pour susciter une réponse spécifique par rapport au produit, au service ou à l&apos;événement</rdfs:comment>
        <rdfs:label xml:lang="fr">Support publicitaire</rdfs:label>
        <skos:altLabel xml:lang="fr">Supports publicitaires</skos:altLabel>
        <skos:prefLabel xml:lang="fr">support publicitaire</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">La réponse attendue est généralement d&apos;inciter les personnes à acquérir, à utiliser ou à participer au produit, au service ou à l&apos;événement annoncé.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT008_5 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT008_5">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008"/>
        <terms:source>https://nomenclature.info/nom/13931</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat8_2</terms:source>
        <rdfs:comment xml:lang="fr">moyen d&apos;expression créé pour communiquer une croyance, une opinion, une réussite personnelle, un statut, un grade, une occupation, une appartenance ou une identité spécifique</rdfs:comment>
        <rdfs:label xml:lang="fr">Symbole personnel</rdfs:label>
        <skos:altLabel xml:lang="fr">attribut</skos:altLabel>
        <skos:altLabel xml:lang="fr">symboles personnels</skos:altLabel>
        <skos:example xml:lang="fr">chevalière;toge;couronne;insigne;plaque de shako;amulette;cocarde;scalp</skos:example>
        <skos:prefLabel xml:lang="fr">symbole personnel</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Un symbole personnel diffère d&apos;un objet pour la cérémonie et le culte en ce qu&apos;il exprime les idées individuelles, et non les idées d&apos;un groupe, ou qu&apos;il communique la relation des personnes à un groupe.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT008_6 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT008_6">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008"/>
        <terms:source>https://nomenclature.info/nom/12895</terms:source>
        <rdfs:comment xml:lang="fr">moyen d&apos;expression créé comme œuvre décorative perçue par le sens de la vue</rdfs:comment>
        <rdfs:label xml:lang="fr">Œuvre visuelle</rdfs:label>
        <skos:altLabel xml:lang="fr">arts visuels</skos:altLabel>
        <skos:hiddenLabel xml:lang="fr">oeuvre visuelle</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">œuvre visuelle</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT009 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT009">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <terms:source>https://nomenclature.info/nom/14135</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#Categorie9</terms:source>
        <rdfs:comment xml:lang="fr">objet élaboré par l&apos;humain créé pour être utilisé comme jouet, pour le jeu, les activités sportives, les jeux de hasard ou le divertissement du public</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet récréatif ou sportif</rdfs:label>
        <skos:altLabel xml:lang="fr">objets récréatifs</skos:altLabel>
        <skos:altLabel xml:lang="fr">sport et divertissement</skos:altLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 09</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 9</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">objet récréatif ou sportif</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT009_1 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT009_1">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT009"/>
        <terms:source>https://nomenclature.info/nom/14351</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat9_2</terms:source>
        <rdfs:comment xml:lang="fr">objet récréatif créé pour une activité participative, généralement non compétitive, autre qu&apos;un jeu ou un exercice athlétique</rdfs:comment>
        <rdfs:label xml:lang="fr">Appareil récréatif</rdfs:label>
        <skos:altLabel xml:lang="fr">appareils récréatifs</skos:altLabel>
        <skos:altLabel xml:lang="fr">équipement récréosportif</skos:altLabel>
        <skos:example xml:lang="fr">billard électrique;glissoire;balançoire;carrousel</skos:example>
        <skos:prefLabel xml:lang="fr">appareil récréatif</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classse comprend l&apos;équipement de divertissement, que cet équipement soit propriété publique ou privée et qu&apos;il y ait ou non des frais reliés à son utilisation.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT009_2 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT009_2">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT009"/>
        <terms:source>https://nomenclature.info/nom/14709</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/jouet</terms:source>
        <terms:source>https://www.cnrtl.fr/definition/jouet</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat9_5</terms:source>
        <rdfs:comment xml:lang="fr">objet récréatif créé pour s&apos;amuser, généralement utilisé par les enfants</rdfs:comment>
        <rdfs:label xml:lang="fr">Jouet</rdfs:label>
        <skos:altLabel xml:lang="fr">jouets</skos:altLabel>
        <skos:example xml:lang="fr">poupée;animal en peluche;balle;toupie;cerf-volant;bilboquet;cube;cerceau</skos:example>
        <skos:prefLabel xml:lang="fr">jouet</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Les jouets représentent des objets fonctionnels ou des choses vivantes, et incluent également les objets conçus principalement pour le jeu.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT009_3 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT009_3">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT009"/>
        <terms:source>https://nomenclature.info/nom/14289</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat9_1</terms:source>
        <rdfs:comment xml:lang="fr">objet récréatif créé pour la présentation d’un divertissement non compétitif devant des spectateurs</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le divertissement du public</rdfs:label>
        <skos:altLabel xml:lang="fr">appareils de divertissement public</skos:altLabel>
        <skos:altLabel xml:lang="fr">équipement récréoculturel</skos:altLabel>
        <skos:example xml:lang="fr">trapèze;masque</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour le divertissement du public</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT009_4 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT009_4">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT009"/>
        <terms:source>https://nomenclature.info/nom/14136</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat9_4</terms:source>
        <rdfs:comment xml:lang="fr">objet récréatif créé pour une activité compétitive fondée sur le hasard, la résolution de problème ou le calcul, plutôt que sur un effort physique intense, et qui se déroule selon des règles établies</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le jeu</rdfs:label>
        <skos:altLabel>équipement pour le jeu</skos:altLabel>
        <skos:example xml:lang="fr">domino;bille;jeu de cartes</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour le jeu</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT009_41 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT009_41">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT009_4"/>
        <terms:source>https://nomenclature.info/nom/15185</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le jeu créé pour le faciliter</rdfs:comment>
        <rdfs:label xml:lang="fr">Accessoire de jeu</rdfs:label>
        <skos:altLabel xml:lang="fr">accessoires et composants de jeu</skos:altLabel>
        <skos:prefLabel xml:lang="fr">accessoire de jeu</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/COMP001 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/COMP001">
