        <terms:source>https://www.cnrtl.fr/definition/crayon</terms:source>
        <rdfs:comment xml:lang="fr">instrument comprenant une tige d&apos;un morceau de minéral tendre, enfermée dans du bois, du plastique ou du métal, servant à écrire ou à dessiner</rdfs:comment>
        <rdfs:label xml:lang="fr">Crayon</rdfs:label>
        <skos:prefLabel xml:lang="fr">crayon</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0171 -->


