        <rdfs:label xml:lang="fr">Cheval à bascule</rdfs:label>
        <skos:prefLabel xml:lang="fr">cheval à bascule</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0041 -->


