        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/%C3%A9glise</terms:source>
        <rdfs:comment xml:lang="fr">construction servant à réunir les fidèles de la religion catholique ou orthodoxe pour l&apos;exercice du culte public</rdfs:comment>
        <rdfs:label xml:lang="fr">Église</rdfs:label>
        <skos:prefLabel xml:lang="fr">église</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/MIR0118 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/MIR0118">
