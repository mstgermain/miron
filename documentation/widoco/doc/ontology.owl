    <!-- http://www.cidoc-crm.org/cidoc-crm/P73_has_translation -->


    <rdf:Description rdf:about="http://www.cidoc-crm.org/cidoc-crm/P73_has_translation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
    </rdf:Description>
    


    <!-- http://www.cidoc-crm.org/cidoc-crm/P86_falls_within -->


    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P86_falls_within"/>
    


    <!-- http://www.cidoc-crm.org/cidoc-crm/P89_falls_within -->


    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P89_falls_within"/>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/accessoireObjet -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/accessoireObjet">
        <owl:inverseOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetAccessoire"/>
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Objet élaboré par l&apos;humain » à une ou plusieurs instances de la classe « Chose matérielle élaborée par l&apos;humain », qu&apos;elle complète ou pour laquelle elle améliore le fonctionnement</rdfs:comment>
        <rdfs:label xml:lang="fr">est accessoire de</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette relation correspond à la relation de contiguïté Accessoire-Objet.</skos:editorialNote>
        <skos:editorialNote xml:lang="fr">une perche à égoportrait (Objet pour la photographie) est un accessoire de (accessoireObjet) un téléphone intelligent (Objet pour la télécommunication)</skos:editorialNote>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/choseMotif -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/choseMotif">
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E70_Thing"/>
        <rdfs:range rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0176"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Chose » à une ou plusieurs instances de la classe « Motif » ornant la première instance d&apos;un thème ornemental ou figuratif, habituellement répété</rdfs:comment>
        <rdfs:label xml:lang="fr">a pour motif</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/contenantContenu -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/contenantContenu">
        <owl:inverseOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/contenuContenant"/>
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Objet élaboré par l&apos;humain » à une ou plusieurs instances de la classe « Entité CRM » représentant le contenu prévu pour la première instance</rdfs:comment>
        <rdfs:label xml:lang="fr">a pour contenu</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette propriété correspond à la relation de contiguïté Contenant-Contenu.</skos:editorialNote>
        <skos:example xml:lang="fr">une custode (Contenant) a comme contenu (contenantContenu) une hostie consacrée (Objet du culte catholique)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/contenuContenant -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/contenuContenant">
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Entité CRM » à une ou plusieurs instances de « Objet élaboré par l&apos;humain » représentant le contenant prévu pour un contenu donné</rdfs:comment>
        <rdfs:label xml:lang="fr">a pour contenant</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette propriété correspond à la relation de contiguïté Contenu-Contenant.</skos:editorialNote>
        <skos:example xml:lang="fr">une hostie consacrée (Objet du culte catholique) a comme contenant (contenuContenant) une custode (Contenant)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/elementObjet -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/elementObjet">
        <owl:inverseOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Chose matérielle élaborée par l&apos;humain » à une ou plusieurs instances de la classe « Objet élaboré par l’humain » possédant une structure définie reflétant son découpage en composantes (éléments) entretenant une relation fonctionnelle avec le tout</rdfs:comment>
        <rdfs:label xml:lang="fr">fait partie de</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette propriété correspond à la relation partitive Élément-Objet.</skos:editorialNote>
        <skos:editorialNote xml:lang="fr">Cette relation possède la propriété de fonctionnalité, c&apos;est-à-dire que le concept partitif (élément) remplit une fonction du concept intégrant (objet).</skos:editorialNote>
        <skos:editorialNote xml:lang="fr">Cette relation possède la propriété de séparabilité, c&apos;est-à-dire que le concept partitif (élément) peut être séparé du concept intégrant (objet) sans que l&apos;identité du concept intégrant ne soit affectée.</skos:editorialNote>
        <skos:example xml:lang="fr">une anse (Caractéristique élaborée par l&apos;humain) fait partie de (elementObjet) une tasse (Objet pour le service des aliments)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/ensembleMembre -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/ensembleMembre">
        <owl:inverseOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/membreEnsemble"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Objet élaboré par l&apos;humain » à une ou plusieurs instances de la même classe qui fait partie d&apos;un ensemble impliquant une proximité avec les membres et non pas une similarité, chaque membre occupant une fonction spécifique dans l&apos;ensemble</rdfs:comment>
        <rdfs:label xml:lang="fr">est composé de</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette propriété correspond à la relation partitive Ensemble-Membre.</skos:editorialNote>
        <skos:editorialNote xml:lang="fr">Cette relation possède la propriété de séparabilité, c&apos;est-à-dire que le concept partitif (membre) peut être séparé du concept intégrant (ensemble) sans que l&apos;identité du concept intégrant ne soit affectée.</skos:editorialNote>
        <skos:example xml:lang="fr">un jeu de dames (Objet pour le jeu) est composé de (ensembleMembre) un pion (Accessoire ou composant de jeu)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/instrumentPatient -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/instrumentPatient">
        <owl:inverseOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/patientInstrument"/>
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Objet élaboré par l’humain » à une ou plusieurs instances de la classe « Entité CRM » subissant ou étant l&apos;objet d&apos;une action découlant de l&apos;usage prévu de l&apos;objet</rdfs:comment>
        <rdfs:label xml:lang="fr">a pour patient</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette relation correspond à la relation instrumentale Instrument-Patient.</skos:editorialNote>
        <skos:example xml:lang="fr">un porte-bébé (Véhicule à propulsion ou à traction humaine) a comme patient (instrumentPatient) un bébé (Personne)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/manipulationObjet -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/manipulationObjet">
        <owl:inverseOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetManipulation"/>
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Chose matérielle élaborée par l&apos;humain » à une instance de la classe « Objet élaboré par l&apos;humain » qui doit être présente afin de permettre ou faciliter l&apos;usage de la seconde</rdfs:comment>
        <rdfs:label xml:lang="fr">permet de manipuler</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette relation correspond à la relation instrumentale Objet utilisé pour sa manipulation-Objet.</skos:editorialNote>
        <skos:example xml:lang="fr">un arc (Arme blanche) permet de manipuler (manipulationObjet) une flèche (Arme blanche)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/materiauComposantMateriauCompose -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/materiauComposantMateriauCompose">
        <owl:inverseOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/materiauComposeMateriauComposant"/>
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Matériau » à une ou plusieurs instances de la même classe, la première instance étant un élément, soit un autre matériau, qui constitue, compose, la seconde</rdfs:comment>
        <rdfs:label xml:lang="fr">constitue</rdfs:label>
        <skos:example xml:lang="fr">la fibre de coton (Fibre) constitue (materiauComposantMateriauCompose) un tissu en coton (Tissu)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/materiauComposeMateriauComposant -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/materiauComposeMateriauComposant">
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Matériau » à une ou plusieurs instances de la même classe, la première instance étant composée, constituée, de la seconde</rdfs:comment>
        <rdfs:label xml:lang="fr">est constitué de</rdfs:label>
        <skos:example xml:lang="fr">un tissu de coton (Tissu) est composé de (materiauCompoeMateriauComposant) la fibre de coton (Fibre)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/materiauOrganismeVivant -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/materiauOrganismeVivant">
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <rdfs:range rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0226"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Matériau » à une instance de la classe « Organisme vivant » de laquelle la matériau est issu, peu importe sa nature</rdfs:comment>
        <rdfs:label xml:lang="fr">provient de</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette propriété correspond à la relation complexe Matériau-Organisme vivant.</skos:editorialNote>
        <skos:example xml:lang="fr">la fibre de coton (Fibre) provient de (materiauOrganismeVivant) le cotonnier (Végétal)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/membreEnsemble -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/membreEnsemble">
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Objet élaboré par l&apos;humain » à une ou plusieurs instances de la même classe, la première instance faisant partie d&apos;un ensemble impliquant une proximité avec les membres et non pas une similarité, chaque membre occupant une fonction spécifique dans l&apos;ensemble</rdfs:comment>
        <rdfs:label xml:lang="fr">fait partie de</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette propriété correspond à la relation partitive Membre-Ensemble.</skos:editorialNote>
        <skos:editorialNote xml:lang="fr">Cette relation possède la propriété de séparabilité, c&apos;est-à-dire que le concept partitif (membre) peut être séparé du concept intégrant (ensemble) sans que l&apos;identité du concept intégrant ne soit affectée.</skos:editorialNote>
        <skos:example xml:lang="fr">un pion (Accessoire ou composant de jeu) fait partie de (membreEnsemble) un jeu de dames (Objet pour le jeu)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/objetAccessoire -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/objetAccessoire">
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Objet élaboré par l&apos;humain » à une ou plusieurs instances de la classe « Chose matérielle élaborée par l&apos;humain », la première instance étant complétée par la seconde, ou son fonctionnement étant amélioré par la seconde</rdfs:comment>
        <rdfs:label xml:lang="fr">a pour accessoire</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette relation correspond à la relation de contiguïté Objet-Accessoire.</skos:editorialNote>
        <skos:example xml:lang="fr">un téléphone intelligent (Objet pour la télécommunication) a pour accessoire (objetAccessoire) une perche à égoportrait (Objet pour la photographie)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/objetElement -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/objetElement">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Objet élaboré par l’humain » à une ou plusieurs instances de la classe « Chose matérielle élaborée par l&apos;humain », la première possédant une structure définie reflétant son découpage en composantes (éléments) entretenant une relation fonctionnelle avec le tout</rdfs:comment>
        <rdfs:label xml:lang="fr">comprend</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette propriété correspond à la relation partitive Objet-Élément.</skos:editorialNote>
        <skos:editorialNote xml:lang="fr">Cette relation possède la propriété de fonctionnalité, c&apos;est-à-dire que le concept partitif (élément) remplit une fonction du concept intégrant (objet).</skos:editorialNote>
        <skos:editorialNote xml:lang="fr">Cette relation possède la propriété de séparabilité, c&apos;est-à-dire que le concept partitif (élément) peut être séparé du concept intégrant (objet) sans que l&apos;identité du concept intégrant ne soit affectée.</skos:editorialNote>
        <skos:example xml:lang="fr">une tasse (Objet pour le service des aliments) comprend (objetElement) une anse (Caractéristique élaborée par l&apos;humain)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/objetManipulation -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/objetManipulation">
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Objet élaboré par l&apos;humain » à une ou plusieurs instances de la classe « Chose matérielle élaborée par l&apos;humain », la première instance nécessitant la présence de la seconde pour permettre ou faciliter son usage</rdfs:comment>
        <rdfs:label xml:lang="fr">est manipulé par</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette relation correspond à la relation instrumentale Objet-Objet utilisé pour sa manipulation.</skos:editorialNote>
        <skos:example xml:lang="fr">une flèche (Arme blanche) peut être manipulée par (objetManipulation) un arc (Arme blanche)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/objetProduit -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/objetProduit">
        <owl:inverseOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitObjet"/>
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E70_Thing"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Objet élaboré par l&apos;humain » à une ou plusieurs instances de la classe « Chose » représentant le résultat issu de l&apos;utilisation prévue de la première instance</rdfs:comment>
        <rdfs:label xml:lang="fr">permet de produire</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette propriété correspond à la relation d&apos;origine Objet-Produit.</skos:editorialNote>
        <skos:example xml:lang="fr">un appareil photographique (Objet pour la photographie) permet de produire (objetProduit) une photographie (Objet documentaire et Œuvre d&apos;art)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/patientInstrument -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/patientInstrument">
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Entité CRM » à une ou plusieurs instances de la classe « Objet élaboré par l&apos;humain », la première instance subissant ou étant l&apos;objet d&apos;une action découlant de l&apos;usage prévu de la seconde</rdfs:comment>
        <rdfs:label xml:lang="fr">est patient de</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette relation correspond à la relation instrumentale Patient-Instrument.</skos:editorialNote>
        <skos:editorialNote xml:lang="fr">un bébé (Personne) est patient de (patientInstrument) un porte-bébé (Véhicule à propulsion ou à traction humaine)</skos:editorialNote>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/patientTraitement -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/patientTraitement">
        <rdfs:subPropertyOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/patientInstrument"/>
        <owl:inverseOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/traitementPatient"/>
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Matériau » à une instance de la classe « Objet élaboré par l&apos;humain », la première instance pouvant être traitée, soit contrôlée, surveillée, récoltée, recueillie, transformée, modifiée ou servie par le biais de l&apos;utilisation prévue de la seconde instance</rdfs:comment>
        <rdfs:label xml:lang="fr">peut être traité par</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/permetDeServir -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/permetDeServir">
        <rdfs:subPropertyOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/traitementPatient"/>
        <rdfs:domain rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004_4"/>
        <rdfs:range rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0271"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Objet pour le service des aliments » à une ou plusieurs instances de la classe « Aliment » qui peut être servie, pour la consommation, par le biais de l&apos;utilisation prévue de la première instance</rdfs:comment>
        <rdfs:label xml:lang="fr">permet de servir</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/procedeOuTechniqueResultat -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/procedeOuTechniqueResultat">
        <owl:inverseOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/resultatProcedeOuTechnique"/>
        <rdfs:domain rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0227"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E70_Thing"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de la classe « Technique ou Procédé » et une ou plusieurs instances de la classe « Chose » l&apos;ayant produite, c&apos;est-à-dire qu&apos;une technique ou un procédé est mis en oeuvre pour obtenir ce type d&apos;objet</rdfs:comment>
        <rdfs:label xml:lang="fr">a pour résultat</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette relation correspond à la relation d&apos;activité Procédé ou technique-Résultat.</skos:editorialNote>
        <skos:example xml:lang="fr">la technique de la broderie (Technique ou procédé d’ouvrage à l’aiguille) a pour résultat (procedeOuTechniqueResultat) une broderie (Œuvre visuelle) résulte de (resultatProcedeOuTechnique)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/produitMateriau -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau">
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de la classe « Objet élaboré par l&apos;humain » et une ou plusieurs instances de la classe « Matériau » la constituant, c&apos;est-à-dire que l&apos;objet est un tout rassemblant un ou plusieurs matériaux</rdfs:comment>
        <rdfs:label xml:lang="fr">est constitué de</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette relation correspond à la relation d&apos;origine Produit-Matériau.</skos:editorialNote>
        <skos:example xml:lang="fr">un bureau (Meuble) est constitué de (produitMateriau) bois (Matière végétale)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/produitObjet -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/produitObjet">
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E70_Thing"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Chose » à une instance de la classe « Objet élaboré par l&apos;humain », la première instance représentant le résultat issu de l&apos;utilisation prévue de la seconde instance</rdfs:comment>
        <rdfs:label xml:lang="fr">est produit par</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette propriété correspond à la relation d&apos;origine Produit-Objet.</skos:editorialNote>
        <skos:editorialNote xml:lang="fr">une photographie (Objet documentaire et Œuvre d&apos;art) est produit par (produitObjet) un appareil photographique (Objet pour la photographie)</skos:editorialNote>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/produitSupport -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/produitSupport">
        <rdfs:subPropertyOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <terms:source xml:lang="fr">https://usito.usherbrooke.ca/d%C3%A9finitions/support</terms:source>
        <rdfs:comment xml:lang="fr">relation unissant une instance de la classe « Objet élaboré par l&apos;humain » et une ou plusieurs instances de la classe « Matériau » étant un élément matériel susceptible de recevoir une œuvre visuelle ou un matériau sur lequel on fait l&apos;impression</rdfs:comment>
        <rdfs:label xml:lang="fr">a pour support</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette relation correspond à la relation complexe Produit-Support.</skos:editorialNote>
        <skos:example xml:lang="fr">une affiche (Support publicitaire) a pour support (produitSupport) le papier cartonné (Papier)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/resultatProcedeOuTechnique -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/resultatProcedeOuTechnique">
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E70_Thing"/>
        <rdfs:range rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0227"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de la classe « Chose » et une ou plusieurs instances de la classe « Technique ou procédé » la produisant, c&apos;est-à-dire qu&apos;une technique ou un procédé est mis en oeuvre pour obtenir ce type d&apos;objet</rdfs:comment>
        <rdfs:label xml:lang="fr">résulte de</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette relation correspond à la relation d&apos;activité Résultat-Procédé ou technique.</skos:editorialNote>
        <skos:example xml:lang="fr">une broderie (Œuvre visuelle) résulte de (resultatProcedeOuTechnique) la technique de la broderie (Technique ou procédé d’ouvrage à l’aiguille)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/souvenirEntite -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/souvenirEntite">
        <rdfs:domain rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT008_21"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Souvenir » à une instance de la classe « Entité CRM » dont la première instance remet en mémoire, rappelle le souvenir de la seconde instance</rdfs:comment>
        <rdfs:label xml:lang="fr">rappelle ou commémore</rdfs:label>
        <skos:example xml:lang="fr">une assiette commémorative (Souvenir) rappelle ou commémore (souvenirEntite) Élisabeth II (Personne)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/traitementPatient -->


    <owl:ObjectProperty rdf:about="https://stgermain.ebsi.umontreal.ca/miron/traitementPatient">
        <rdfs:subPropertyOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/instrumentPatient"/>
        <rdfs:domain rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
        <rdfs:comment xml:lang="fr">relation unissant une instance de « Objet élaboré par l&apos;humain » à une ou plusieurs instances de la classe « Matériau » qui peut être traitée, soit contrôlée, surveillée, récoltée, recueillie, transformée, modifiée ou servie par le biais de l&apos;usage prévu de la première instance</rdfs:comment>
        <rdfs:label xml:lang="fr">permet de traiter</rdfs:label>
        <skos:editorialNote xml:lang="fr">Cette relation correspond à la relation instrumentale Traitement-Patient.</skos:editorialNote>
        <skos:example>un chalumeau (Objet pour le traitement des aliments) permet de traiter (traitementPatient) l&apos;eau d&apos;érable (Matière végétale)</skos:example>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.cidoc-crm.org/cidoc-crm/E11_Modification -->


    <rdf:Description rdf:about="http://www.cidoc-crm.org/cidoc-crm/E11_Modification">
        <owl:equivalentClass rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E80_Part_Removal"/>
    </rdf:Description>
    


    <!-- http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity -->


    <rdf:Description rdf:about="http://www.cidoc-crm.org/cidoc-crm/E1_CRM_Entity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </rdf:Description>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/AdditionAssemblage -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/AdditionAssemblage">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0227"/>
        <terms:source>http://vocab.getty.edu/page/aat/300229467</terms:source>
        <rdfs:comment xml:lang="fr">procédé ou technique permettant d&apos;ajouter des éléments à d&apos;autres ou à les réunir</rdfs:comment>
        <rdfs:label xml:lang="fr">Procédé ou technique d’addition ou d’assemblage</rdfs:label>
        <skos:prefLabel xml:lang="fr">procédé ou technique d’addition ou d’assemblage</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/Animal -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/Animal">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0226"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/animal#aaF25c7fd6560e76</terms:source>
        <terms:source>https://vitrinelinguistique.oqlf.gouv.qc.ca/fiche-gdt/fiche/8352383/animal</terms:source>
        <rdfs:comment xml:lang="fr">organisme vivant organisé, élémentaire ou complexe, doué de sensibilité et généralement doué de mobilité</rdfs:comment>
        <rdfs:label xml:lang="fr">Animal</rdfs:label>
        <skos:hiddenLabel xml:lang="fr">animalia</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">animal</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT001 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT001">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <terms:source>https://nomenclature.info/nom/2</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#Categorie1</terms:source>
        <rdfs:comment xml:lang="fr">objet élaboré par l&apos;humain créé pour définir l&apos;espace des activités humaines ou pour servir d&apos;éléments délimitant l&apos;espace</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet de l’environnement bâti</rdfs:label>
        <skos:altLabel xml:lang="fr">construction et éléments distinctifs</skos:altLabel>
        <skos:altLabel xml:lang="fr">objets de l&apos;environnement bâti</skos:altLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 01</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 1</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">objet de l’environnement bâti</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT001_1 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT001_1">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT001"/>
        <terms:source>https://nomenclature.info/nom/543</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat1_1</terms:source>
        <rdfs:comment xml:lang="fr">objet de l&apos;environnement bâti créé pour fournir ou délimiter un espace destiné aux activités humaines</rdfs:comment>
        <rdfs:label xml:lang="fr">Construction</rdfs:label>
        <skos:altLabel xml:lang="fr">Bâtiment</skos:altLabel>
        <skos:altLabel xml:lang="fr">Constructions</skos:altLabel>
        <skos:example xml:lang="fr">section d&apos;un mur;section d&apos;un toit</skos:example>
        <skos:prefLabel xml:lang="fr">construction</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Les constructions peuvent être permantentes, portatives, à régulation climatique ou à libre circulation de l&apos;air et peuvent servir à diverses fins cérémonielles, agricoles, récréatives, commerciales, culturelles, civiques, industrielles ou sociales.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT002 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT002">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <terms:source>https://nomenclature.info/nom/967</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#Categorie2</terms:source>
        <rdfs:comment xml:lang="fr">objet élaboré par l&apos;humain créé pour faciliter l&apos;activité humaine et pour répondre aux besoins matériels des personnes, en assurant confort, commodité ou protection</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour l’ameublement de l’environnement bâti</rdfs:label>
        <skos:altLabel xml:lang="fr">ameublement et accessoires</skos:altLabel>
        <skos:altLabel xml:lang="fr">ameublement et décoration</skos:altLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 02</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 2</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">objet pour l’ameublement de l’environnement bâti</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">L&apos;ameublement est constitué d&apos;objets permettant l&apos;activité humaine en lui fournissant un cadre passif.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT002_1 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT002_1">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT002"/>
        <terms:source>https://nomenclature.info/nom/1499</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat2_1</terms:source>
        <rdfs:comment xml:lang="fr">objet pour l&apos;ameublement de l&apos;environnement bâti créé pour être disposé à l&apos;intérieur ou autour d&apos;un bâtiment pour la commodité des personnes, c&apos;est-à-dire afin d&apos;améliorer, de compléter ou de faciliter l&apos;entretien de leur environnement</rdfs:comment>
        <rdfs:label xml:lang="fr">Accessoire ménager</rdfs:label>
        <skos:altLabel xml:lang="fr">accessoire de maison</skos:altLabel>
        <skos:altLabel xml:lang="fr">accessoires ménagers</skos:altLabel>
        <skos:example xml:lang="fr">porte-savon;crachoir;aquarium;cendrier;têtière;nappe;plateau de cartes de visite;caisse</skos:example>
        <skos:prefLabel xml:lang="fr">accessoire ménager</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend de petits accessoires, des objets autres que du mobilier servant au rangement et à la présentation ainsi que des objets protégeant les meubles.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT002_2 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT002_2">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT002"/>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat2_8</terms:source>
        <rdfs:comment xml:lang="fr">objet pour l&apos;ameublement de l&apos;environnement bâti créé pour répondre aux besoins d&apos;hygiène de la vie de tous les jours et conçu pour être fixé, en tant que partie intégrante, aux conduites d&apos;eau et d&apos;égout, souvent à l&apos;intérieur d&apos;une construction</rdfs:comment>
        <rdfs:label xml:lang="fr">Appareil sanitaire</rdfs:label>
        <skos:altLabel xml:lang="fr">sanitaire</skos:altLabel>
        <skos:example xml:lang="fr">baignoire;robinet;évier;lavabo</skos:example>
        <skos:prefLabel xml:lang="fr">appareil sanitaire</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT002_3 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT002_3">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT002"/>
        <terms:source>https://nomenclature.info/nom/968</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat2_4</terms:source>
        <rdfs:comment xml:lang="fr">objet pour l&apos;ameublement de l&apos;environnement bâti créé pour être utilisé comme article de literie ou accessoire de lit</rdfs:comment>
        <rdfs:label xml:lang="fr">Literie</rdfs:label>
        <skos:example xml:lang="fr">couverture;oreiller;hamac;sac de couchage</skos:example>
        <skos:prefLabel xml:lang="fr">literie</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT002_4 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT002_4">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT002"/>
        <terms:source>https://nomenclature.info/nom/1062</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat2_5</terms:source>
        <rdfs:comment xml:lang="fr">objet pour l&apos;ameublement de l&apos;environnement bâti créé pour répondre aux besoins matériels des personnes et pour assurer leur confort dans leurs espaces de vie et de travail</rdfs:comment>
        <rdfs:label xml:lang="fr">Meuble</rdfs:label>
        <skos:altLabel xml:lang="fr">meubles</skos:altLabel>
        <skos:altLabel xml:lang="fr">mobilier</skos:altLabel>
        <skos:example xml:lang="fr">bureau;table;lit;chaise;meuble d&apos;extérieur</skos:example>
        <skos:prefLabel xml:lang="fr">meuble</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT002_5 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT002_5">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT002"/>
        <terms:source>https://nomenclature.info/nom/1654</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat2_3</terms:source>
        <rdfs:comment xml:lang="fr">objet pour l&apos;ameublement de l&apos;environnement bâti créé pour l&apos;éclairage</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour l’éclairage</rdfs:label>
        <skos:altLabel xml:lang="fr">éclairage</skos:altLabel>
        <skos:altLabel xml:lang="fr">équipement d&apos;éclairage</skos:altLabel>
        <skos:example xml:lang="fr">mouchette;coupe-mèche;lanterne à kérosène;lampadaire;projecteur de scène;éteignoir;accessoire de phare</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour l’éclairage</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT002_6 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT002_6">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT002"/>
        <terms:source>https://nomenclature.info/nom/1030</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat2_7</terms:source>
        <rdfs:comment xml:lang="fr">objet pour l&apos;ameublement de l&apos;environnement bâti créé pour couvrir, de façon temporaire ou amovible, le sol à l&apos;intérieur ou à l&apos;extérieur d&apos;un bâtiment</rdfs:comment>
        <rdfs:label xml:lang="fr">Revêtement de sol</rdfs:label>
        <skos:altLabel xml:lang="fr">revêtements de sol</skos:altLabel>
        <skos:example xml:lang="fr">carpette;paillasson;tapis</skos:example>
        <skos:prefLabel xml:lang="fr">revêtement de sol</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT003 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT003">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <terms:source>https://nomenclature.info/nom/1934</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#Categorie3</terms:source>
        <rdfs:comment xml:lang="fr">objet élaboré par l&apos;humain créé pour répondre aux besoins personnels d&apos;habillement, d&apos;ornementation, de protection du corps ou de toilette</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet personnel</rdfs:label>
        <skos:altLabel xml:lang="fr">objets personnels</skos:altLabel>
        <skos:altLabel xml:lang="fr">vêtements et accessoires</skos:altLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 03</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 3</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">objet personnel</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT003_1 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT003_1">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT003"/>
        <terms:source>https://nomenclature.info/nom/2987</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat3_1</terms:source>
        <rdfs:comment xml:lang="fr">objet personnel créé pour la toilette, l&apos;hygiène, les soins personnels ou les soins esthétiques</rdfs:comment>
        <rdfs:label xml:lang="fr">Article de toilette</rdfs:label>
        <skos:altLabel xml:lang="fr">accessoire de toilette</skos:altLabel>
        <skos:altLabel xml:lang="fr">articles de toilette</skos:altLabel>
        <skos:example xml:lang="fr">rasoir;brosse à dents;maquillage</skos:example>
        <skos:prefLabel xml:lang="fr">article de toilette</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT003_2 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT003_2">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT003"/>
        <terms:source>https://nomenclature.info/nom/2694</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat3_2</terms:source>
        <rdfs:comment xml:lang="fr">objet personnel créé pour servir aux personnes d’articles pour l’entretien des vêtements, d’articles pour transporter ou pour ranger des effets personnels, d’articles de protection, d’aides personnelles ou physiques ou d’équipement pour la consommation de tabac ou de substances</rdfs:comment>
        <rdfs:label xml:lang="fr">Article personnel</rdfs:label>
        <skos:altLabel xml:lang="fr">accessoire personnel</skos:altLabel>
        <skos:altLabel xml:lang="fr">articles personnels</skos:altLabel>
        <skos:example xml:lang="fr">quille de gantier;portefeuille;sac à dos;parapluie;lunette de sécurité;canne;lunette;pipe;valise;prothèse</skos:example>
        <skos:prefLabel xml:lang="fr">article personnel</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT003_3 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT003_3">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT003"/>
        <terms:source>https://nomenclature.info/nom/1999</terms:source>
        <rdfs:comment xml:lang="fr">objet personnel créé pour vêtir le corps humain</rdfs:comment>
        <rdfs:label xml:lang="fr">Vêtement</rdfs:label>
        <skos:altLabel xml:lang="fr">vêtements</skos:altLabel>
        <skos:prefLabel xml:lang="fr">vêtement</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT003_31 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT003_31">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT003_3"/>
        <terms:source>https://nomenclature.info/nom/1999</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat3_3</terms:source>
        <rdfs:comment xml:lang="fr">article vestimentaire créé pour être utilisé avec des vêtements ou qui se portent sur les mains, les bras ou le cou, ou créé pour la fixation, la protection ou l’ornementation des vêtements</rdfs:comment>
        <rdfs:label xml:lang="fr">Accessoire vestimentaire</rdfs:label>
        <skos:altLabel xml:lang="fr">accessoires et composants vestimentaires</skos:altLabel>
        <skos:prefLabel xml:lang="fr">accessoire vestimentaire</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT003_32 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT003_32">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT003_3"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/objetElement"/>
                <owl:hasValue rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/9816503e_8680_4f2a_8eb1_75e87c5cb7fb"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://nomenclature.info/nom/2143</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat3_4</terms:source>
        <rdfs:comment xml:lang="fr">article vestimentaire créé pour être porté sur les pieds ou le bas des jambes afin de les protéger ou les couvrir</rdfs:comment>
        <rdfs:label xml:lang="fr">Chaussure</rdfs:label>
        <skos:altLabel>chaussures</skos:altLabel>
        <skos:example xml:lang="fr">botte;bas;guêtre</skos:example>
        <skos:prefLabel xml:lang="fr">chaussure</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT003_33 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT003_33">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT003_3"/>
        <terms:source>https://nomenclature.info/nom/2216</terms:source>
        <rdfs:comment xml:lang="fr">article vestimentaire créé pour être porté sur la tête afin de la protéger ou la couvrir</rdfs:comment>
        <rdfs:label xml:lang="fr">Coiffure</rdfs:label>
        <skos:altLabel xml:lang="fr">coiffures</skos:altLabel>
        <skos:altLabel>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat3_5</skos:altLabel>
        <skos:example xml:lang="fr">bonnet;tricorne;turban</skos:example>
        <skos:prefLabel xml:lang="fr">coiffure</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT003_34 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT003_34">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT003_3"/>
        <terms:source>https://nomenclature.info/nom/2626</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat3_7</terms:source>
        <rdfs:comment xml:lang="fr">article vestimentaire créé pour être porté sous les vêtements principaux, pour protéger les vêtements contre le corps, pour protéger le corps contre les vêtements ou pour prêter une forme ou un soutien à des parties du corps</rdfs:comment>
        <rdfs:label xml:lang="fr">Sous-vêtement</rdfs:label>
        <skos:altLabel xml:lang="fr">sous-vêtements</skos:altLabel>
        <skos:example xml:lang="fr">jupon;corset;caleçon</skos:example>
        <skos:prefLabel xml:lang="fr">sous-vêtement</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT003_35 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT003_35">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT003_3"/>
        <terms:source>https://nomenclature.info/nom/2537</terms:source>
        <rdfs:comment xml:lang="fr">article vestimentaire porté par-dessus les vêtements principaux, habituellement pour se protéger du froid et des intempéries</rdfs:comment>
        <rdfs:label xml:lang="fr">Vêtement de dessus</rdfs:label>
        <skos:altLabel xml:lang="fr">vêtements de dessus</skos:altLabel>
        <skos:prefLabel xml:lang="fr">vêtement de dessus</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT004 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/traitementPatient"/>
                        <owl:allValuesFrom rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E57_Material"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <terms:source>https://nomenclature.info/nom/3176</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#Categorie4</terms:source>
        <rdfs:comment xml:lang="fr">objet élaboré par l&apos;humain créé pour contrôler, surveiller, récolter ou recueillir des ressources ou pour transformer, modifier ou servir certaines matières, premières ou transformées</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le traitement des matériaux</rdfs:label>
        <skos:altLabel xml:lang="fr">outillage et équipement pour le traitement de matières premières</skos:altLabel>
        <skos:altLabel xml:lang="fr">outillage et équipement pour le traitement des matériaux</skos:altLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 04</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 4</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">objet pour le traitement des matériaux</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Les objets pour le traitement des matériaux sont normalement créés pour résoudre des problèmes inhérents aux matériaux eux-mêmes. Ainsi, le bois, par exemple, exige certains types d&apos;appareils de coupe; la pêche nécessite certains appâts; la nourriture requiert certains ustensiles de service et de transformation.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT004_1 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004_1">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
        <terms:source>https://nomenclature.info/nom/3177</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat4_1</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le traitement des matériaux créé pour la culture ou le jardinage</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour l’agriculture</rdfs:label>
        <skos:altLabel xml:lang="fr">agriculture</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, agriculture</skos:altLabel>
        <skos:example xml:lang="fr">semoir</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour l’agriculture</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les instruments d’ensemencement, d’entretien, de récolte et d’entreposage des produits culturaux, ainsi que les appareils de transformation des aliments destinés aux animaux, mais non aux humains.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT004_2 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004_2">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
        <terms:source>https://nomenclature.info/nom/6624</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat4_11</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le traitement des matériaux créé pour le travail avec des matériaux recouvrant les surfaces par le dépôt d&apos;une couche résiduelle comme une couche de peinture, ou par l&apos;emploi d&apos;adhésifs pour poser sur une surface un recouvrement mince comme du papier peint ou de la feuille d&apos;or</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la peinture ou le recouvrement</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, peinture</skos:altLabel>
        <skos:altLabel xml:lang="fr">peinture et recouvrement</skos:altLabel>
        <skos:example xml:lang="fr">couteau à mastiquer;palette;pinceau</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour la peinture ou le recouvrement</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les outils, l’équipement et les fournitures utilisés à des fins décoratives, artistiques et de protection.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT004_3 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004_3">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/instrumentPatient"/>
                <owl:someValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0226"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://nomenclature.info/nom/3802</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat4_10</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le traitement des matériaux créés pour la capture d&apos;animaux aquatiques et terrestres par tout autre moyen que les armes</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la pêche ou le piégeage</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, pêche, chasse et piégeage</skos:altLabel>
        <skos:altLabel xml:lang="fr">pêche et piégeage</skos:altLabel>
        <skos:prefLabel xml:lang="fr">objet pour la pêche ou le piégeage</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT004_4 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004_4">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/permetDeServir"/>
                <owl:someValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0271"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://nomenclature.info/nom/4867</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat4_14</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le traitement des matériaux créé pour la présentation, le service ou la consommation des aliments ou des boissons destinés à la consommation humaine</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le service des aliments</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, service des aliments</skos:altLabel>
        <skos:altLabel xml:lang="fr">service des aliments</skos:altLabel>
        <skos:example xml:lang="fr">soucoupe;tasse;ramasse-miette</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour le service des aliments</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT004_5 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004_5">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/traitementPatient"/>
                        <owl:someValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0271"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
        <terms:source>https://nomenclature.info/nom/3941</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat4_15</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le traitement des matériaux créé pour la transformation, l&apos;entreposage et la préparation des aliments ou des boissons destinés à la consommation humaine</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le traitement des aliments</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, transformation et préparation des aliments</skos:altLabel>
        <skos:altLabel xml:lang="fr">traitement des aliments</skos:altLabel>
        <skos:example xml:lang="fr">tasse à mesurer;réfrigérateur;baratte</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour le traitement des aliments</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les instruments, les appareils et l&apos;équipement utilisé pour transformer les aliments.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT004_6 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004_6">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/traitementPatient"/>
                        <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0197"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
        <terms:source>https://nomenclature.info/nom/6755</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat4_19</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le traitement des matériaux créé pour la préparation de matériaux faits de fibres et pour la préparation de tissus</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le travail des textiles</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, travail du textile</skos:altLabel>
        <skos:altLabel xml:lang="fr">travail des fibres et confection</skos:altLabel>
        <skos:editorialNote xml:lang="fr">Un textile est une fibre qui peut être tissée.</skos:editorialNote>
        <skos:example xml:lang="fr">séran;égreneuse à coton;bobine;métier;dévidoir;fuseau</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour le travail des textiles</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les outils, les pièces d&apos;équipement et les fournitures servant à la fabrication d’objets à partir de tissu ainsi que les outils de préparation des fibres pour la conception de tissus.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT004_7 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004_7">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/traitementPatient"/>
                        <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0083"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
        <terms:source>https://nomenclature.info/nom/7142</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat4_20</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le traitement des matériaux créé pour la fabrication d&apos;objets en bois</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le travail du bois</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, travail du bois</skos:altLabel>
        <skos:altLabel xml:lang="fr">travail du bois</skos:altLabel>
        <skos:example xml:lang="fr">serre-joints;scie;rabot</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour le travail du bois</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les objets utilisés pour fabriquer des produits dérivés à partir de bois modifié physiquement, ou pour fabriquer des objets à partir de ces produits dérivés.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT004_8 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004_8">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/traitementPatient"/>
                        <owl:allValuesFrom rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/MIR0082"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
        <terms:source>https://nomenclature.info/nom/5828</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat4_21</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le traitement des matériaux créé pour la fonderie, l&apos;usinage, coulage, le moulage, le forgeage, le façonnage ou la fabrication des métaux ou des produits métalliques</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le travail du métal</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, travail des métaux</skos:altLabel>
        <skos:altLabel xml:lang="fr">travail du métal</skos:altLabel>
        <skos:example xml:lang="fr">enclume;étau;gueuse</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour le travail du métal</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT004_9 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT004_9">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT004"/>
        <terms:source>https://nomenclature.info/nom/6520</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le traitement des matériaux créé pour transformer ou modifier différents matériaux selon le contexte d’usage</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet à usage polyvalent pour le traitement des matériaux</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, utilisation polyvalente pour le traitement des matériaux</skos:altLabel>
        <skos:prefLabel xml:lang="fr">objet à usage polyvalent pour le traitement des matériaux</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <terms:source>https://nomenclature.info/nom/7685</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#Categorie5</terms:source>
        <rdfs:comment xml:lang="fr">objet élaboré par l&apos;humain créé pour l&apos;observation des phénomènes naturels ou pour l&apos;application des connaissances tirées de ces observations</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour les sciences ou la technologie</rdfs:label>
        <skos:altLabel xml:lang="fr">armement, sciences et technologies</skos:altLabel>
        <skos:altLabel xml:lang="fr">outillage et équipement pour les sciences et la technologie</skos:altLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 05</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 5</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">objet pour les sciences ou la technologie</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Les objets pour les sciences ou la technologie visent généralement à augmenter ou à documenter les connaissances sur le monde qui nous entoure ou pour exprimer ces connaissances. Les sous-classes de cette classe sont apparentées en vertu du fait qu&apos;elles comprennent des objets élaborés par l&apos;humain créés pour exploiter un domaine particulier de connaissances. Elles sont donc basées sur les connaissances plutôt que les matériaux.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_1 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_1">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005"/>
        <terms:source>https://nomenclature.info/nom/10258</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_12</terms:source>
        <rdfs:comment xml:lang="fr">objet pour les sciences ou la technologie créé pour enregistrer ou mesurer le temps</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la chronométrie</rdfs:label>
        <skos:altLabel xml:lang="fr">chronométrie</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, chronométrie</skos:altLabel>
        <skos:prefLabel xml:lang="fr">objet pour la chronométrie</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_10 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_10">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005"/>
        <terms:source>https://nomenclature.info/nom/8952</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_16</terms:source>
        <rdfs:comment xml:lang="fr">objet pour les sciences ou la technologie créé pour les activités de nettoyage, la buanderie ou l&apos;entretien paysager effectués dans ou autour d&apos;un bâtiment privé ou public, qu&apos;elles soient exécutées occasionnellement ou dans le cadre des activités d&apos;une entreprise</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour l’entretien ou la maintenance</rdfs:label>
        <skos:altLabel xml:lang="fr">entretien ménager et maintenance</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, entretien et maintenance</skos:altLabel>
        <skos:example xml:lang="fr">balai;savon;fer à repasser</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour l&apos;entretien ou la maintenance</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les outils spécialisés utilisés pour la restauration et la conservation des objets.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_11 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_11">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005"/>
        <terms:source>https://nomenclature.info/nom/9943</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_23</terms:source>
        <rdfs:comment xml:lang="fr">objet pour les sciences ou la technologie créé pour observer, mesurer ou documenter la lumière</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour l’optique</rdfs:label>
        <skos:altLabel xml:lang="fr">optique</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, optique</skos:altLabel>
        <skos:editorialNote xml:lang="fr">Ici, le terme « optique » désigne la « branche de la physique qui a pour objet l&apos;étude de la lumière et des phénomènes de la vision » (https://usito.usherbrooke.ca/d%C3%A9finitions/optique).</skos:editorialNote>
        <skos:example xml:lang="fr">jumelles;microscope;loupe;spectrographe</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour l&apos;optique</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend l&apos;équipement d’usage courant.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_12 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_12">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005"/>
        <terms:source>https://nomenclature.info/nom/10235</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_15</terms:source>
        <rdfs:comment xml:lang="fr">objet pour les sciences ou la technologie créé pour observer, mesurer ou documenter la chaleur et ses effets</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour l’étude de l’énergie thermique</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, énergie thermique</skos:altLabel>
        <skos:altLabel xml:lang="fr">énergie thermique</skos:altLabel>
        <skos:example xml:lang="fr">thermographe;bolomètre</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour l&apos;étude de l&apos;énergie thermique</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_2 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_2">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005"/>
        <terms:source rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://nomenclature.info/nom/9155</terms:source>
        <terms:source rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_18</terms:source>
        <rdfs:comment xml:lang="fr">objet pour les sciences ou la technologie créé pour l&apos;étude, la mesure ou l&apos;utilisation des propriétés statiques ou dynamiques des solides, des liquides et des gaz</rdfs:comment>
        <rdfs:label xml:lang="en">Objet pour la mécanique</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, mécanique</skos:altLabel>
        <skos:prefLabel xml:lang="fr">objet pour la mécanique</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_3 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_3">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005"/>
        <terms:source xml:lang="fr">outils et équipement, métrologie</terms:source>
        <terms:source>https://nomenclature.info/nom/10318</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_21</terms:source>
        <rdfs:comment xml:lang="fr">objet pour les sciences ou la technologie créé pour observer, enregistrer ou mesurer des masses (poids) ou des dimensions physiques telles que la longueur, la surface ou le volume</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la métrologie</rdfs:label>
        <skos:altLabel xml:lang="fr">métrologie</skos:altLabel>
        <skos:example xml:lang="fr">balance de précision;règle pliante</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour la métrologie</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_4 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_4">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005"/>
        <terms:source>https://nomenclature.info/nom/9856</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_20</terms:source>
        <rdfs:comment xml:lang="fr">objet pour les sciences ou la technologie créé pour observer, mesurer ou documenter les phénomènes atmosphériques</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la météorologie</rdfs:label>
        <skos:altLabel xml:lang="fr">météorologie</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, météorologie</skos:altLabel>
        <skos:example xml:lang="fr">girouette;baromètre</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour la météorologie</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_5 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_5">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005"/>
        <terms:source>https://nomenclature.info/nom/10006</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_26</terms:source>
        <rdfs:comment xml:lang="fr">objet pour les sciences ou la technologie créé pour contrôler le comportement des personnes ou assurer la sécurité ou la protection des biens</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la protection ou la répression</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, répression et protection</skos:altLabel>
        <skos:altLabel xml:lang="fr">protection civile</skos:altLabel>
        <skos:example xml:lang="fr">menottes;fouet;entrave</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour la protection ou la répression</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les objets servant à réaliser les activités courantes d&apos;un organisme public telles que la protection contre l&apos;incendie, la protection de l&apos;ordre public assurée par les corps policiers et le processus électoral.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_6 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_6">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005"/>
        <terms:source>https://nomenclature.info/nom/9786</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_13</terms:source>
        <rdfs:comment xml:lang="fr">objet pour les sciences ou la technologie créé pour faciliter ou permettre l&apos;échange d&apos;argent, de biens ou de services</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le commerce</rdfs:label>
        <skos:altLabel xml:lang="fr">commerce</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, commerce</skos:altLabel>
        <skos:example xml:lang="fr">comptoir;baril;capsule;dame-jeanne</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour le commerce</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les objets servant à présenter des marchandises ainsi que des emballages de produits et des étiquettes.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_7 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_7">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005"/>
        <terms:source>https://nomenclature.info/nom/7734</terms:source>
        <rdfs:comment xml:lang="fr">objet pour les sciences ou la technologie créé pour la chasse, le tir sur cibles, la guerre ou l&apos;autoprotection</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour l’armement</rdfs:label>
        <skos:altLabel xml:lang="fr">Armement</skos:altLabel>
        <skos:prefLabel xml:lang="fr">objet pour l&apos;armement</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_71 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_71">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005_7"/>
        <terms:source>https://nomenclature.info/nom/7807</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_9</terms:source>
        <rdfs:comment xml:lang="fr">objet pour l&apos;armement créé pour être utilisé comme accessoire pour la chasse, le tir sur cibles, la guerre ou l’autoprotection, ou comme objet utilisé pour l&apos;entretien ou l&apos;entreposage des armes</rdfs:comment>
        <rdfs:label xml:lang="fr">Accessoire d’armement</rdfs:label>
        <skos:altLabel xml:lang="fr">accessoire et composant d&apos;armement</skos:altLabel>
        <skos:altLabel xml:lang="fr">attirail</skos:altLabel>
        <skos:example xml:lang="fr">ceinture à cartouchière;cartouchière;ceinturon d&apos;épée;amorces;fourreau;gibecière</skos:example>
        <skos:prefLabel xml:lang="fr">accessoire d’armement</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les accessoires d&apos;armes, d&apos;artillerie ainsi que l&apos;attirail personnel associé à l&apos;armement.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_72 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_72">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005_7"/>
        <terms:source>https://nomenclature.info/nom/8150</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_3</terms:source>
        <rdfs:comment xml:lang="fr">objet pour l&apos;armement créé pour être utilisé comme une arme qui tranche ou perce en tranchant</rdfs:comment>
        <rdfs:label xml:lang="fr">Arme blanche</rdfs:label>
        <skos:altLabel xml:lang="fr">armes blanches</skos:altLabel>
        <skos:example xml:lang="fr">baïonnette;arbalète</skos:example>
        <skos:prefLabel xml:lang="fr">arme blanche</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend notamment les baïonnettes servant d&apos;accessoire aux armes à feu et les outils projetant des armes blanches.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_73 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_73">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005_7"/>
        <terms:source>https://nomenclature.info/nom/8331</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_4</terms:source>
        <rdfs:comment xml:lang="fr">objet pour l&apos;armement créé pour être utilisé comme une arme qui frappe ou écrase par le poids ou la force d&apos;impulsion, ou qui lance des projectiles non explosifs ou non pénétrants</rdfs:comment>
        <rdfs:label xml:lang="fr">Arme contondante</rdfs:label>
        <skos:altLabel xml:lang="fr">armes de percussion</skos:altLabel>
        <skos:example xml:lang="fr">garcette;massue</skos:example>
        <skos:prefLabel xml:lang="fr">arme contondante</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_74 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_74">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005_7"/>
        <terms:source>https://nomenclature.info/nom/8239</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_2</terms:source>
        <rdfs:comment xml:lang="fr">objet pour l&apos;armement créé pour être utilisé comme une arme qui tire des projectiles, pouvant être manié par une seule personne et qui généralement utilise un agent propulseur explosif</rdfs:comment>
        <rdfs:label xml:lang="fr">Arme à feu</rdfs:label>
        <skos:example xml:lang="fr">carabine;pistolet;tromblon</skos:example>
        <skos:prefLabel xml:lang="fr">arme à feu</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_8 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_8">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005"/>
        <terms:source>https://nomenclature.info/nom/10098</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_6</terms:source>
        <rdfs:comment xml:lang="fr">objet pour les sciences ou la technologie créé pour déterminer la position d&apos;un observateur par rapport à des points de référence connus ou pour indiquer la forme et l&apos;étendue d&apos;une région, comme une surface terrestre</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour l’arpentage ou la navigation</rdfs:label>
        <skos:altLabel xml:lang="fr">arpentage et navigation</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, arpentage et navigation</skos:altLabel>
        <skos:example xml:lang="fr">sextant;théodolite</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour l&apos;arpentage ou la navigation</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les instruments conçus pour prendre des mesures linéaires et angulaires.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT005_9 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT005_9">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT005"/>
        <terms:source>https://nomenclature.info/nom/8354</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat5_8</terms:source>
        <rdfs:comment xml:lang="fr">objet pour les sciences ou la technologie créé pour observer, mesurer ou documenter les objets et les événements hors de l&apos;atmosphère terrestre</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour l’astronomie</rdfs:label>
        <skos:altLabel xml:lang="fr">astronomie</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, astronomie</skos:altLabel>
        <skos:example xml:lang="fr">astrolabe;télescope</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour l&apos;astronomie</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT006 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <terms:source>https://nomenclature.info/nom/10378</terms:source>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/communiquer</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#Categorie6</terms:source>
        <rdfs:comment xml:lang="fr">objet élaboré par l&apos;humain créé pour permettre la communication, c&apos;est-à-dire l&apos;action de faire part, de donner connaissance de quelque chose à quelqu&apos;un</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la communication</rdfs:label>
        <skos:altLabel xml:lang="fr">outillage et équipement pour la communication</skos:altLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 06</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 6</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">objet pour la communication</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT006_1 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_1">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006"/>
        <terms:source>https://nomenclature.info/nom/11153</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat6_2</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la communication créé pour générer, amplifier, reproduire ou stocker de la musique, des mots parlés ou d&apos;autres sons utiles à la communication humaine, à l’exception des instruments de musique</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la communication sonore</rdfs:label>
        <skos:altLabel xml:lang="fr">communication sonore</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, communication sonore</skos:altLabel>
        <skos:example xml:lang="fr">carillons;microphone;porte-voix</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour la communication sonore</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT006_2 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_2">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006"/>
        <terms:source>https://nomenclature.info/nom/11365</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat6_3</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la communication créé pour faciliter la communication au moyen de symboles, de motifs, de couleurs, de textes ou de photographies qui sont directement observables et intelligibles pour le destinataire, ou pour être utilisé comme appareil de signalisation, comme moyen de regarder des images photographiques ou d&apos;autres types d&apos;images</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la communication visuelle</rdfs:label>
        <skos:altLabel xml:lang="fr">communication visuelle</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, communication visuelle</skos:altLabel>
        <skos:example xml:lang="fr">feu de signalisation;projecteur de cinéma;projecteur de diapositives</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour la communication visuelle</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT006_3 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_3">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006"/>
        <terms:source>https://nomenclature.info/nom/11446</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat6_1</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la communication créé pour faciliter la communication entre les personnes par l&apos;intermédiaire de documents écrits, soit la préparation et la gestion de ces documents</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la communication écrite</rdfs:label>
        <skos:altLabel xml:lang="fr">communication écrite</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, communication écrite</skos:altLabel>
        <skos:example xml:lang="fr">plume;encre;papier;agenda;pique-notes;sous-main</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour la communication écrite</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT006_4 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_4">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006"/>
        <terms:source>https://nomenclature.info/nom/10607</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat6_6</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la communication créé pour produire des sons musicaux ou pour être incorporés de façon audible dans des exécutions musicales</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la musique</rdfs:label>
        <skos:altLabel xml:lang="fr">musique</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, musique</skos:altLabel>
        <skos:example xml:lang="fr">piano;saxophone;violon</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour la musique</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les appareils utilisés de façon active dans l&apos;exécution de la musique.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT006_41 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_41">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_4"/>
        <terms:source>https://nomenclature.info/nom/10608</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la musique créé pour faciliter la production de sons musicaux par des moyens manuels, mécaniques ou électroniques, mais qui ne produisent pas eux-mêmes de tels sons</rdfs:comment>
        <rdfs:label xml:lang="fr">Accessoire musical</rdfs:label>
        <skos:altLabel xml:lang="fr">accessoires et composants musicaux</skos:altLabel>
        <skos:prefLabel xml:lang="fr">accessoire musical</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT006_42 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_42">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_4"/>
        <terms:source>https://nomenclature.info/nom/10655</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la musique créé pour produire des sons musicaux</rdfs:comment>
        <rdfs:label xml:lang="fr">Instrument de musique</rdfs:label>
        <skos:altLabel xml:lang="fr">instruments de musique</skos:altLabel>
        <skos:prefLabel xml:lang="fr">instrument de musique</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT006_421 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_421">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_42"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/produitMateriau"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass>
                            <owl:Class>
                                <owl:oneOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://stgermain.ebsi.umontreal.ca/miron/5cf6c853_b36d_4346_9772_be4dc5087043"/>
                                </owl:oneOf>
                            </owl:Class>
                        </owl:onClass>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_42"/>
        <rdfs:comment xml:lang="fr">instrument de musique dont le son résulte de la mise en vibration d&apos;une ou de plusieurs cordes</rdfs:comment>
        <rdfs:label xml:lang="fr">Instrument à cordes</rdfs:label>
        <skos:prefLabel xml:lang="fr">instrument à cordes</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT006_422 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_422">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006_42"/>
        <terms:source>https://usito.usherbrooke.ca/d%C3%A9finitions/vent#bbb92dd19938e649</terms:source>
        <rdfs:comment xml:lang="fr">instrument de musique dont le son résulte de la mise en vibration de la colonne d&apos;air qu&apos;il contient</rdfs:comment>
        <rdfs:label xml:lang="fr">Instrument à vent</rdfs:label>
        <skos:prefLabel xml:lang="fr">instrument à vent</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT006_5 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_5">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006"/>
        <terms:source>https://nomenclature.info/nom/10864</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat6_7</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la communication créé pour fixer une image permanente par des moyens optiques, chimiques ou numériques</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la photographie</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, photographie</skos:altLabel>
        <skos:altLabel xml:lang="fr">photographie</skos:altLabel>
        <skos:example xml:lang="fr">appareil photographique;cuve à développement;agrandisseur;filtre;trépied</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour la photographie</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT006_6 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_6">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006"/>
        <terms:source>https://nomenclature.info/nom/11268</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat6_8</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la communication créé pour faciliter la communication à distance, par des moyens électriques ou électroniques</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la télécommunication</rdfs:label>
        <skos:altLabel xml:lang="fr">outils et équipement, télécommunication</skos:altLabel>
        <skos:altLabel xml:lang="fr">télécommunication</skos:altLabel>
        <skos:example xml:lang="fr">téléphone;télégraphe;radio;téléviseur;câble;transmetteur;antenne</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour la télécommunication</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT006_7 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT006_7">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT006"/>
        <terms:source>https://nomenclature.info/nom/10545</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat6_4</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la communication créé pour la création de dessins de précision, des plans architecturaux, des conceptions mécaniques, des cartes ou des graphiques</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le graphisme</rdfs:label>
        <skos:altLabel xml:lang="fr">graphisme</skos:altLabel>
        <skos:altLabel xml:lang="fr">outils et équipement, graphisme</skos:altLabel>
        <skos:example xml:lang="fr">équerre;table à dessin;compas;tire-ligne</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour le graphisme</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les instruments utilisés pour enregistrer les observations d&apos;arpentage et de navigation.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT007 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT007">
        <rdfs:subClassOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E22_Human-Made_Object"/>
        <terms:source>https://nomenclature.info/nom/11633</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#Categorie7</terms:source>
        <rdfs:comment xml:lang="fr">objet élaboré par l&apos;humain créé pour transporter des personnes ou des animaux ou pour distribuer des marchandises, ou pour faciliter ce transport ou en complément d&apos;un tel transport</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour la manutention ou le transport</rdfs:label>
        <skos:altLabel xml:lang="fr">objets de manutention et de transport</skos:altLabel>
        <skos:altLabel xml:lang="fr">transport et manutention</skos:altLabel>
        <skos:editorialNote xml:lang="fr">Puisque l&apos;équipement de transport est complexe et que les éléments sont souvent collectionnés de façon indépendante, certaines sous-classes sont subdivisées.</skos:editorialNote>
        <skos:example xml:lang="fr">automobile;brouette</skos:example>
        <skos:hiddenLabel xml:lang="fr">catégorie 07</skos:hiddenLabel>
        <skos:hiddenLabel xml:lang="fr">catégorie 7</skos:hiddenLabel>
        <skos:prefLabel xml:lang="fr">objet pour la manutention ou le transport</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT007_1 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT007_1">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT007"/>
        <terms:source>https://nomenclature.info/nom/12262</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat7_4</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la manutention et le transport créé pour transporter des personnes ou des biens sur ou le long d&apos;une route fixe déterminée par une voie, un rail, un câble ou un dispositif similaire, ou pour faciliter ce transport</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le transport ferroviaire</rdfs:label>
        <skos:altLabel xml:lang="fr">transport ferroviaire</skos:altLabel>
        <skos:altLabel xml:lang="fr">équipement de transport ferroviaire</skos:altLabel>
        <skos:example xml:lang="fr">locomotive;wagon</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour le transport ferroviaire</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT007_11 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT007_11">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT007_1"/>
        <terms:source>https://nomenclature.info/nom/12263</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat7_5</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le transport ferroviaire créé comme accessoire pour le transport de personnes ou de biens sur ou le long d&apos;une route fixe déterminée par une voie, un rail, un câble ou un dispositif similaire</rdfs:comment>
        <rdfs:label xml:lang="fr">Accessoire pour le transport ferroviaire</rdfs:label>
        <skos:altLabel xml:lang="fr">accessoires et composants de transport ferroviaire</skos:altLabel>
        <skos:altLabel xml:lang="fr">accessoires pour le transport ferroviaire</skos:altLabel>
        <skos:prefLabel xml:lang="fr">accessoire pour le transport ferroviaire</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT007_12 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT007_12">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT007_1"/>
        <terms:source>https://nomenclature.info/nom/12318</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le transport ferroviaire créé pour être utilisé comme moyen de transport sur ou le long d&apos;une route fixe déterminée par une voie, un rail, un câble ou un dispositif similaire</rdfs:comment>
        <rdfs:label xml:lang="fr">Véhicule ferroviaire</rdfs:label>
        <skos:prefLabel xml:lang="fr">véhicule ferroviaire</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT007_2 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT007_2">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT007"/>
        <terms:source>https://nomenclature.info/nom/12392</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat7_6</terms:source>
        <rdfs:comment xml:lang="fr">objet pour la manutention ou le transport créé pour transporter des personnes ou des biens sur ou sous l&apos;eau</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet pour le transport maritime</rdfs:label>
        <skos:altLabel xml:lang="fr">transport maritime</skos:altLabel>
        <skos:altLabel xml:lang="fr">équipement de transport maritime</skos:altLabel>
        <skos:example xml:lang="fr">canot;chaland;sous-marin</skos:example>
        <skos:prefLabel xml:lang="fr">objet pour le transport maritime</skos:prefLabel>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT007_21 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT007_21">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT007_2"/>
        <terms:source>https://nomenclature.info/nom/12393</terms:source>
        <terms:source>https://www.musees.qc.ca/fr/professionnel/guidesel/doccoll/fr/classificationethno/classificationethnodefinition.htm#souscat7_7</terms:source>
        <rdfs:comment xml:lang="fr">objet pour le transport maritime créé comme accessoire pour le transport de personnes ou de biens sur ou sous l&apos;eau</rdfs:comment>
        <rdfs:label xml:lang="fr">Accessoire pour le transport maritime</rdfs:label>
        <skos:altLabel xml:lang="fr">accessoires et composants de transport maritime</skos:altLabel>
        <skos:altLabel xml:lang="fr">accessoires pour le transport maritime</skos:altLabel>
        <skos:example xml:lang="fr">cordage;cabestan;aviron;pompe</skos:example>
        <skos:prefLabel xml:lang="fr">accessoire pour le transport maritime</skos:prefLabel>
        <skos:scopeNote xml:lang="fr">Cette classe comprend les objets créés pour faire partie des embarcations.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://stgermain.ebsi.umontreal.ca/miron/CAT007_22 -->


    <owl:Class rdf:about="https://stgermain.ebsi.umontreal.ca/miron/CAT007_22">
        <rdfs:subClassOf rdf:resource="https://stgermain.ebsi.umontreal.ca/miron/CAT007_2"/>
